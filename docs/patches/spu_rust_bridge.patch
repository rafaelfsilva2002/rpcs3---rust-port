+#include "stdafx.h"
+#include "SPURustBridge.h"
+
+#include "SPUThread.h"
+#include "Utilities/StrUtil.h"
+#include "Emu/Memory/vm.h"  // R7.2 — for vm::_ptr<u8>(eal) in the
+                            // runtime DMA GET callback.
+
+#include <atomic>
+#include <cstdlib>
+#include <cstring>
+#include <memory>
+#include <mutex>
+#include <unordered_map>
+
+#ifdef RPCS3_HAS_SPU_RUST_BRIDGE
+#include "rpcs3_spu_ffi.h"
+#endif
+
+LOG_CHANNEL(spu_rust_bridge_log, "RustSPU");
+
+namespace spu_rust_bridge
+{
+	// -1 = uncached, 0 = disabled, 1 = enabled.
+	static std::atomic<int> s_enabled_cache{-1};
+
+	bool is_enabled()
+	{
+#ifdef RPCS3_HAS_SPU_RUST_BRIDGE
+		int cached = s_enabled_cache.load(std::memory_order_relaxed);
+		if (cached < 0)
+		{
+			const char* env = std::getenv("RPCS3_SPU_RUST_BRIDGE");
+			cached = (env && env[0] == '1' && env[1] == '\0') ? 1 : 0;
+
+			// Race-safe: multiple threads may compute the same value
+			// concurrently. Whichever wins the store is fine — the
+			// computation is deterministic.
+			s_enabled_cache.store(cached, std::memory_order_relaxed);
+
+			if (cached == 1)
+			{
+				spu_rust_bridge_log.success(
+					"[Rust SPU bridge] RPCS3_SPU_RUST_BRIDGE=1 detected; "
+					"bridge ENABLED globally for this RPCS3 process. "
+					"R6.5b delegated-execution scope: mailbox + SNR "
+					"workloads (no DMA/MFC, no SPURS). Multi-round handling: "
+					"StallRead on IN_MBOX/SNR1/SNR2 blocks via RPCS3 pop_wait "
+					"+ resumes the same Rust handle; StallWrite on OUT_MBOX "
+					"(ch28) drains intermediate value into RPCS3 ch_out_mbox "
+					"(depth-1 overwrite, matches PSL1GHT-cooperative semantics) "
+					"and resumes. Verified: single_spu_mailbox_v1, "
+					"single_spu_branch_loop_v1, single_spu_loadstore_v1, "
+					"single_spu_signal_v1, single_spu_mailbox_multi_v1 "
+					"(R6.5 stall_iters=1 proven on real binary). StallWrite "
+					"path covered by FFI test rust_spu_outmbox_backpressure_via_ffi "
+					"(real-binary fixture for StallWrite ch28 not realizable in "
+					"PSL1GHT cooperative model — see docs/SPU_RUST_BRIDGE_PATCH.md).");
+			}
+		}
+		return cached == 1;
+#else
+		return false;
+#endif
+	}
+
+	void hello_world_proof(spu_thread& spu)
+	{
+#ifdef RPCS3_HAS_SPU_RUST_BRIDGE
+		rust_spu_t* h = rust_spu_new();
+		if (!h)
+		{
+			spu_rust_bridge_log.error(
+				"[Rust SPU bridge] rust_spu_new() returned null; "
+				"FFI link is broken or process is OOM. spu_thread '%s' "
+				"will continue with the existing C++ executor.",
+				spu.get_name());
+			return;
+		}
+
+		spu_rust_bridge_log.success(
+			"[Rust SPU bridge] hello-world FFI roundtrip OK on "
+			"spu_thread '%s' (lv2_id=0x%x). Static linkage of "
+			"rpcs3_spu_ffi.lib confirmed; rust_spu_t handle "
+			"allocated + dropped cleanly.",
+			spu.get_name(), spu.lv2_id);
+
+		rust_spu_drop(h);
+#else
+		(void)spu;
+		spu_rust_bridge_log.warning(
+			"[Rust SPU bridge] RPCS3_HAS_SPU_RUST_BRIDGE not defined; "
+			"the Rust staticlib was not present at CMake configure "
+			"time. Run scripts/build_rust_spu_ffi.{sh,ps1} and "
+			"re-configure CMake to enable the bridge.");
+#endif
+	}
+
+#ifdef RPCS3_HAS_SPU_RUST_BRIDGE
+	// Encode a 128-bit GPR (RPCS3 v128, native LE in memory) as a
+	// 16-byte big-endian buffer matching the Rust FFI's contract:
+	// `bytes[0]` = preferred-slot MSB.
+	//
+	// SPU preferred slot in RPCS3's LE layout is `_u32[3]`. The
+	// canonical SPU big-endian register layout is:
+	//   word 0 (preferred slot) -> bytes[0..3]
+	//   word 1                  -> bytes[4..7]
+	//   word 2                  -> bytes[8..11]
+	//   word 3                  -> bytes[12..15]
+	// So `bytes[i*4 .. i*4+3]` = BE encoding of `gpr._u32[3 - i]`.
+	static void v128_to_be_bytes(const v128& v, u8 (&bytes)[16])
+	{
+		for (u32 i = 0; i < 4; ++i)
+		{
+			const u32 word = v._u32[3 - i];
+			bytes[i * 4 + 0] = static_cast<u8>(word >> 24);
+			bytes[i * 4 + 1] = static_cast<u8>(word >> 16);
+			bytes[i * 4 + 2] = static_cast<u8>(word >> 8);
+			bytes[i * 4 + 3] = static_cast<u8>(word >> 0);
+		}
+	}
+
+	// R7.2 — runtime DMA GET callback. Reads `size` bytes from RPCS3
+	// EA `eal` via `vm::_ptr<u8>` (the same path the C++ executor uses
+	// in `process_mfc_cmd()`'s simple-GET branch — see SPUThread.cpp
+	// line 2091) and copies them into `dst_ls_ptr` (a writable pointer
+	// into the Rust SPU handle's LS at the captured `mfc_lsa`). The
+	// Rust interpreter has already validated cmd=0x40, eah=0, tag<32,
+	// size, lsa+size<=256 KiB before calling here.
+	//
+	// `user_data` is the originating `spu_thread*` (passed at callback
+	// install time, used for diagnostic logging). Returns 0 on
+	// success, -1 if the EA does not map to host memory (the bridge
+	// then surfaces MfcUnsupported and falls back to C++).
+	static int32_t bridge_dma_get_callback(
+		void* user_data,
+		uint32_t eal,
+		uint8_t* dst_ls_ptr,
+		uint32_t size,
+		uint32_t tag)
+	{
+		spu_thread* spu = static_cast<spu_thread*>(user_data);
+		const u8* src = vm::_ptr<const u8>(eal);
+		if (!src)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] bridge_dma_get_callback: vm::_ptr<u8>(0x%x) "
+				"returned null on '%s'; refusing GET, bridge will fall back to C++",
+				eal, spu ? spu->get_name().c_str() : "<unknown>");
+			return -1;
+		}
+		std::memcpy(dst_ls_ptr, src, size);
+		spu_rust_bridge_log.success(
+			"[Rust SPU bridge] R7.2 DMA GET dispatched: cmd=0x40 eal=0x%x size=%u "
+			"tag=%u on '%s'; real EA/LS path (vm::_ptr<u8>); tag-stat 0x%x queued "
+			"for subsequent rdch ch24",
+			eal, size, tag, spu ? spu->get_name().c_str() : "<unknown>",
+			1u << tag);
+		return 0;
+	}
+
+	// R8.1 — runtime DMA PUT callback. Symmetric to GET but inverts
+	// the data direction: reads `size` bytes from `src_ls_ptr` (a
+	// read-only pointer into the Rust SPU handle's LS at the
+	// captured `mfc_lsa`) and writes them to RPCS3 EA `eal` via
+	// `vm::_ptr<u8>` (matches the C++ executor's PUT branch in
+	// `process_mfc_cmd()`). The Rust interpreter has already
+	// validated cmd=0x20, eah=0, tag<32, size, lsa+size<=256 KiB
+	// before calling here.
+	//
+	// Returns 0 on success, -1 if the EA does not map to host
+	// memory (bridge surfaces MfcUnsupported, falls back to C++).
+	static int32_t bridge_dma_put_callback(
+		void* user_data,
+		uint32_t eal,
+		const uint8_t* src_ls_ptr,
+		uint32_t size,
+		uint32_t tag)
+	{
+		spu_thread* spu = static_cast<spu_thread*>(user_data);
+		u8* dst = vm::_ptr<u8>(eal);
+		if (!dst)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] bridge_dma_put_callback: vm::_ptr<u8>(0x%x) "
+				"returned null on '%s'; refusing PUT, bridge will fall back to C++",
+				eal, spu ? spu->get_name().c_str() : "<unknown>");
+			return -1;
+		}
+		std::memcpy(dst, src_ls_ptr, size);
+		spu_rust_bridge_log.success(
+			"[Rust SPU bridge] R8.1 DMA PUT dispatched: cmd=0x20 eal=0x%x size=%u "
+			"tag=%u on '%s'; real LS/EA path (vm::_ptr<u8>); tag-stat 0x%x queued "
+			"for subsequent rdch ch24",
+			eal, size, tag, spu ? spu->get_name().c_str() : "<unknown>",
+			1u << tag);
+		return 0;
+	}
+
+	// R8.4d -- runtime DMA GETL (list-DMA EA->LS) callback. The
+	// Rust interpreter has already validated cmd=0x44, eah=0,
+	// tag<32, descriptor_size > 0 and % 8 == 0 and <= 0x800,
+	// descriptor_lsa + descriptor_size <= 256 KiB before calling
+	// here. The handler:
+	// 1. Walks each 8-byte BE descriptor at descriptor_ls_ptr:
+	//      [0]: sb (bit 0x80 = stall-and-notify, R8.5+ scope)
+	//      [1]: pad
+	//      [2..3]: BE u16 ts
+	//      [4..7]: BE u32 ea (data EA per element)
+	// 2. Validates per element:
+	//    - sb & 0x80 == 0 (no stall-and-notify)
+	//    - ts > 0 and ts <= 0x4000 (R6.7 per-element cap)
+	//    - cumulative destination LS within 256 KiB
+	//    - vm::_ptr<u8>(ea) accessible
+	// 3. Copies each element from vm::_ptr<u8>(ea) to
+	//    dest_ls_ptr + cumulative_offset (raw ts sum advance,
+	//    no padding-up; matches Cell BE observed in R8.4b
+	//    capture: LS[0x10000..0x10080] = elem 0 (128 B);
+	//    LS[0x10080..0x100C0] = elem 1 (64 B)).
+	// 4. Returns 0 on success, -1 on any validation failure
+	//    (interpreter surfaces MfcUnsupported, bridge falls
+	//    back to C++).
+	//
+	// `user_data` is the originating `spu_thread*` (passed at
+	// callback install time, used for diagnostic logging).
+	static int32_t bridge_dma_getl_callback(
+		void* user_data,
+		uint32_t descriptor_lsa,
+		const uint8_t* descriptor_ls_ptr,
+		uint32_t descriptor_size,
+		uint32_t lsa_dest_base,
+		uint8_t* dest_ls_ptr,
+		uint32_t tag)
+	{
+		spu_thread* spu = static_cast<spu_thread*>(user_data);
+		const char* name = spu ? spu->get_name().c_str() : "<unknown>";
+
+		if (!descriptor_ls_ptr || descriptor_size == 0 || descriptor_size % 8 != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] bridge_dma_getl_callback: invalid descriptor "
+				"(ptr=%p size=%u) on '%s'; refusing GETL, bridge will fall back",
+				static_cast<const void*>(descriptor_ls_ptr), descriptor_size, name);
+			return -1;
+		}
+
+		const uint32_t element_count = descriptor_size / 8u;
+		uint32_t cumulative_offset = 0;
+		uint32_t total_transferred = 0;
+
+		for (uint32_t i = 0; i < element_count; ++i)
+		{
+			const uint8_t* d = descriptor_ls_ptr + i * 8;
+			const uint8_t sb = d[0];
+			const uint16_t ts = static_cast<uint16_t>((d[2] << 8) | d[3]);
+			const uint32_t ea = (static_cast<uint32_t>(d[4]) << 24)
+				| (static_cast<uint32_t>(d[5]) << 16)
+				| (static_cast<uint32_t>(d[6]) << 8)
+				|  static_cast<uint32_t>(d[7]);
+
+			if (sb & 0x80)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_getl_callback: element %u has "
+					"stall-and-notify bit set on '%s'; refusing GETL (R8.5+ scope)",
+					i, name);
+				return -1;
+			}
+			if (ts == 0 || ts > 0x4000)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_getl_callback: element %u ts=%u "
+					"out of (0, 0x4000] on '%s'; refusing GETL",
+					i, ts, name);
+				return -1;
+			}
+			// Cumulative LS bounds check.
+			if (static_cast<uint64_t>(lsa_dest_base) + cumulative_offset + ts > 0x40000ull)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_getl_callback: element %u "
+					"lsa_dest=0x%x cumulative=0x%x + ts=%u exceeds 256 KiB on '%s'; "
+					"refusing GETL",
+					i, lsa_dest_base, cumulative_offset, ts, name);
+				return -1;
+			}
+			const uint8_t* src = vm::_ptr<const uint8_t>(ea);
+			if (!src)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_getl_callback: element %u "
+					"vm::_ptr<u8>(0x%x) returned null on '%s'; refusing GETL",
+					i, ea, name);
+				return -1;
+			}
+			std::memcpy(dest_ls_ptr + cumulative_offset, src, ts);
+			cumulative_offset += ts;
+			total_transferred += ts;
+		}
+
+		spu_rust_bridge_log.success(
+			"[Rust SPU bridge] R8.4d DMA GETL dispatched: "
+			"descriptor_lsa=0x%x descriptor_size=%u element_count=%u "
+			"lsa_dest=0x%x transferred_bytes=%u tag=%u on '%s'; real EA->LS "
+			"path (vm::_ptr<u8> per element); tag-stat 0x%x queued for "
+			"subsequent rdch ch24 (cmd=0x44 GETL / 0x45 GETLB / 0x46 GETLF "
+			"all route here per R8.4f-a — barrier/fence stripped at "
+			"do_list_transfer)",
+			descriptor_lsa, descriptor_size, element_count,
+			lsa_dest_base, total_transferred, tag, name,
+			1u << tag);
+		return 0;
+	}
+
+	// R8.4e -- runtime DMA PUTL (list-DMA LS->EA) callback.
+	// Symmetric inverse of bridge_dma_getl_callback: same
+	// descriptor walk + per-element validation, but the copy
+	// direction is LS -> EA. The Rust interpreter has already
+	// validated cmd=0x24, eah=0, tag<32, descriptor_size > 0
+	// and % 8 == 0 and <= 0x800, descriptor_lsa + descriptor_size
+	// <= 256 KiB. The handler:
+	// 1. Walks each 8-byte BE descriptor at descriptor_ls_ptr:
+	//      [0]: sb (bit 0x80 = stall-and-notify, R8.5+ scope)
+	//      [1]: pad
+	//      [2..3]: BE u16 ts
+	//      [4..7]: BE u32 ea (data EA destination per element)
+	// 2. Validates per element:
+	//    - sb & 0x80 == 0 (no stall-and-notify)
+	//    - ts > 0 and ts <= 0x4000 (R6.7 per-element cap)
+	//    - cumulative source LS within 256 KiB
+	//    - vm::_ptr<u8>(ea) accessible
+	// 3. Copies each element from src_ls_ptr + cumulative_offset
+	//    to vm::_ptr<u8>(ea) (raw ts sum advance, no padding-up).
+	//    NOTE: src_ls_ptr is `const uint8_t*` -- PUTL never
+	//    mutates LS, only reads from it.
+	// 4. Returns 0 on success, -1 on any validation failure
+	//    (interpreter surfaces MfcUnsupported, bridge falls
+	//    back to C++).
+	//
+	// `user_data` is the originating `spu_thread*` (passed at
+	// callback install time, used for diagnostic logging).
+	static int32_t bridge_dma_putl_callback(
+		void* user_data,
+		uint32_t descriptor_lsa,
+		const uint8_t* descriptor_ls_ptr,
+		uint32_t descriptor_size,
+		uint32_t lsa_src_base,
+		const uint8_t* src_ls_ptr,
+		uint32_t tag)
+	{
+		spu_thread* spu = static_cast<spu_thread*>(user_data);
+		const char* name = spu ? spu->get_name().c_str() : "<unknown>";
+
+		if (!descriptor_ls_ptr || descriptor_size == 0 || descriptor_size % 8 != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] bridge_dma_putl_callback: invalid descriptor "
+				"(ptr=%p size=%u) on '%s'; refusing PUTL, bridge will fall back",
+				static_cast<const void*>(descriptor_ls_ptr), descriptor_size, name);
+			return -1;
+		}
+		if (!src_ls_ptr)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] bridge_dma_putl_callback: null src_ls_ptr "
+				"on '%s'; refusing PUTL, bridge will fall back", name);
+			return -1;
+		}
+
+		const uint32_t element_count = descriptor_size / 8u;
+		uint32_t cumulative_offset = 0;
+		uint32_t total_transferred = 0;
+
+		for (uint32_t i = 0; i < element_count; ++i)
+		{
+			const uint8_t* d = descriptor_ls_ptr + i * 8;
+			const uint8_t sb = d[0];
+			const uint16_t ts = static_cast<uint16_t>((d[2] << 8) | d[3]);
+			const uint32_t ea = (static_cast<uint32_t>(d[4]) << 24)
+				| (static_cast<uint32_t>(d[5]) << 16)
+				| (static_cast<uint32_t>(d[6]) << 8)
+				|  static_cast<uint32_t>(d[7]);
+
+			if (sb & 0x80)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_putl_callback: element %u has "
+					"stall-and-notify bit set on '%s'; refusing PUTL (R8.5+ scope)",
+					i, name);
+				return -1;
+			}
+			if (ts == 0 || ts > 0x4000)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_putl_callback: element %u ts=%u "
+					"out of (0, 0x4000] on '%s'; refusing PUTL",
+					i, ts, name);
+				return -1;
+			}
+			// Cumulative source LS bounds check.
+			if (static_cast<uint64_t>(lsa_src_base) + cumulative_offset + ts > 0x40000ull)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_putl_callback: element %u "
+					"lsa_src=0x%x cumulative=0x%x + ts=%u exceeds 256 KiB on '%s'; "
+					"refusing PUTL",
+					i, lsa_src_base, cumulative_offset, ts, name);
+				return -1;
+			}
+			uint8_t* dst = vm::_ptr<uint8_t>(ea);
+			if (!dst)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] bridge_dma_putl_callback: element %u "
+					"vm::_ptr<u8>(0x%x) returned null on '%s'; refusing PUTL",
+					i, ea, name);
+				return -1;
+			}
+			std::memcpy(dst, src_ls_ptr + cumulative_offset, ts);
+			cumulative_offset += ts;
+			total_transferred += ts;
+		}
+
+		spu_rust_bridge_log.success(
+			"[Rust SPU bridge] R8.4e DMA PUTL dispatched: cmd=0x24 "
+			"descriptor_lsa=0x%x descriptor_size=%u element_count=%u "
+			"lsa_src=0x%x transferred_bytes=%u tag=%u on '%s'; real LS->EA "
+			"path (vm::_ptr<u8> per element); tag-stat 0x%x queued for "
+			"subsequent rdch ch24",
+			descriptor_lsa, descriptor_size, element_count,
+			lsa_src_base, total_transferred, tag, name,
+			1u << tag);
+		return 0;
+	}
+
+	static const char* outcome_name(rust_spu_outcome_t o)
+	{
+		switch (o)
+		{
+		case rust_spu_outcome_t_Continue:        return "Continue";
+		case rust_spu_outcome_t_Stop:            return "Stop";
+		case rust_spu_outcome_t_StallRead:       return "StallRead";
+		case rust_spu_outcome_t_StallWrite:      return "StallWrite";
+		case rust_spu_outcome_t_Error:           return "Error";
+		case rust_spu_outcome_t_MfcUnsupported:  return "MfcUnsupported";
+		}
+		return "Unknown";
+	}
+
+	// R6.4 channel classification.
+	// Maps the 7-bit channel index returned in `out_code` for
+	// StallRead / StallWrite outcomes to a human-readable name +
+	// re-tryability classification. The Rust SPU subset (per
+	// `rpcs3-spu-thread::ch`) handles ch 0/1/2/3/4/7/8/22/23/28/29/30;
+	// MFC channels (16..21) are explicitly NOT in the subset and
+	// surface as `Error` rather than `Stall*`.
+	struct StallClass
+	{
+		const char* name;       // "IN_MBOX (ch29)" etc.
+		bool potentially_retryable; // true ⇒ R6.4b could re-invoke
+		                            //   after a PPU-side action
+		                            //   that fills/drains the channel
+	};
+
+	static StallClass classify_stall_channel(u32 ch)
+	{
+		switch (ch)
+		{
+		// Mailbox-class — future R6.4b can re-invoke after
+		// `sysSpuThreadWriteMb` (IN_MBOX) or PPU OUT_MBOX drain.
+		case 29: return { "IN_MBOX (ch29)",         true };
+		case 28: return { "OUT_MBOX (ch28)",        true };
+		// Signal-class — future R6.4b can re-invoke after
+		// `sysSpuThreadWriteSignal`.
+		case 3:  return { "SNR1 (ch3)",             true };
+		case 4:  return { "SNR2 (ch4)",             true };
+		// Event-class — rare; would need event_stat plumbing.
+		case 0:  return { "EVENTSTAT (ch0)",        false };
+		case 1:  return { "EVENTMASK_W (ch1)",      false };
+		case 2:  return { "EVENTACK (ch2)",         false };
+		case 22: return { "EVENTMASK_R (ch22)",     false };
+		case 23: return { "MACHSTAT (ch23)",        false };
+		// Decrementer — timing-dependent; out of R6.4 scope.
+		case 7:  return { "WRDEC (ch7)",            false };
+		case 8:  return { "RDDEC (ch8)",            false };
+		case 30: return { "OUT_INTR_MBOX (ch30)",   false };
+		// MFC / DMA — explicitly out of scope; the Rust subset does
+		// not even decode the writes, so this case should be
+		// unreachable in practice (Error fires first). Keeping the
+		// label for completeness.
+		case 21: return { "MFC_Cmd (ch21, DMA)",    false };
+		default: return { "unknown channel",        false };
+		}
+	}
+
+	// =====================================================================
+	// R6.4b — persistent-handle session infrastructure.
+	// =====================================================================
+	//
+	// Side-table keyed by `spu_thread::lv2_id` (a stable u32 set by the
+	// LV2 kernel when the SPU thread is initialized; unique within an
+	// emulator process). The map owns each `rust_spu_t*` via RAII
+	// (deleter calls `rust_spu_drop`). Mutex serializes access; in
+	// practice contention is very low — at most one SPU thread per
+	// lv2_id touches its own session, and the only cross-thread reader
+	// would be a hypothetical R6.4c+ wake-up path.
+	//
+	// Lifecycle:
+	//   - First entry to `try_delegate_execution` for a given spu_thread
+	//     creates the session (allocate handle, load LS/PC/GPR, peek
+	//     channels, push to Rust).
+	//   - `try_delegate_execution` then runs a multi-round loop within
+	//     the same call: every Stop commits and drops the session;
+	//     supported `StallRead` (mailbox/SNR) blocks via RPCS3-side
+	//     `pop_wait` (matches the C++ executor pattern in
+	//     `spu_thread::get_ch_value`), forwards the popped value to
+	//     Rust, and continues the loop. Any other outcome
+	//     (Continue / unsupported Stall / Error) drops the session and
+	//     returns false (clean fallback to C++).
+	//   - The side-table is structured to support cross-call session
+	//     survival (sessions persisting across `try_delegate_execution`
+	//     invocations) — future R6.4c work. In R6.4b sessions are
+	//     always dropped before the function returns.
+	struct BridgeSession
+	{
+		rust_spu_t* handle;
+		u32 lv2_id;
+		u32 in_mbox_consumed;       // count of values popped from RPCS3 IN_MBOX into Rust
+		bool snr1_forwarded;        // true if we ever forwarded a value to Rust slot 0
+		bool snr2_forwarded;        // true if we ever forwarded a value to Rust slot 1
+		u32 stall_iterations;       // count of StallRead→pop_wait→resume cycles (R6.4b)
+		u32 stall_write_iterations; // count of StallWrite→drain→resume cycles (R6.5b)
+		u32 total_steps;            // accumulated step count across iterations
+	};
+
+	struct BridgeSessionDeleter
+	{
+		void operator()(BridgeSession* s) const
+		{
+			if (s)
+			{
+				if (s->handle)
+				{
+					rust_spu_drop(s->handle);
+				}
+				delete s;
+			}
+		}
+	};
+
+	using BridgeSessionPtr = std::unique_ptr<BridgeSession, BridgeSessionDeleter>;
+
+	static std::mutex s_sessions_mutex;
+	static std::unordered_map<u32, BridgeSessionPtr> s_sessions;
+
+	static BridgeSession* find_session(u32 lv2_id)
+	{
+		std::lock_guard<std::mutex> lk(s_sessions_mutex);
+		auto it = s_sessions.find(lv2_id);
+		return it != s_sessions.end() ? it->second.get() : nullptr;
+	}
+
+	// Insert a fresh session (caller must guarantee no existing entry).
+	// Returns a borrowed pointer; ownership stays with the side-table.
+	static BridgeSession* insert_session(u32 lv2_id, rust_spu_t* handle)
+	{
+		std::lock_guard<std::mutex> lk(s_sessions_mutex);
+		BridgeSessionPtr s(new BridgeSession{
+			handle, lv2_id, /*in_mbox_consumed=*/0u,
+			/*snr1=*/false, /*snr2=*/false,
+			/*stall_iters=*/0u, /*stall_write_iters=*/0u,
+			/*total_steps=*/0u});
+		BridgeSession* raw = s.get();
+		s_sessions[lv2_id] = std::move(s);
+		return raw;
+	}
+
+	// Drop the session (frees the handle via the unique_ptr deleter).
+	static void drop_session(u32 lv2_id)
+	{
+		std::lock_guard<std::mutex> lk(s_sessions_mutex);
+		s_sessions.erase(lv2_id);
+	}
+#endif
+
+	bool try_delegate_execution(spu_thread& spu)
+	{
+#ifdef RPCS3_HAS_SPU_RUST_BRIDGE
+		// =========================================================
+		// Phase 0 — handle alloc + LS + PC + GPR setup + session
+		// registration in the side-table.
+		// These touch ONLY Rust state, never RPCS3 state, so any
+		// failure here is a clean fallback.
+		// =========================================================
+
+		// In R6.4b we always start fresh (sessions never survive
+		// across `try_delegate_execution` calls — they live only for
+		// the multi-round loop below). The side-table API is set up
+		// to support cross-call survival in a future R6.4c, but
+		// here we treat any leftover entry as stale and drop it.
+		drop_session(spu.lv2_id);
+
+		rust_spu_t* h = rust_spu_new();
+		if (!h)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_new() returned null; "
+				"falling back to C++ executor on '%s'", spu.get_name());
+			return false;
+		}
+
+		// R7.1 — enable the honest-fallback gate for MFC/DMA channels.
+		// Any subsequent `wrch` to ch16..=23 or `rdch` ch24/ch25 (or
+		// `rchcnt` on any of those) will short-circuit BEFORE touching
+		// any per-channel state and surface
+		// `rust_spu_outcome_t_MfcUnsupported` UNLESS the R7.2 runtime
+		// DMA GET callback (installed immediately below) handles it.
+		// The interpreter prefers the callback path over the refuse
+		// gate when both are present (see `SpuChannels::write` —
+		// "gate relaxed when dma_get_callback is some").
+		if (rust_spu_set_refuse_mfc(h, 1) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_set_refuse_mfc(1) failed on '%s'; "
+				"falling back to C++ executor (the staticlib appears stale — rebuild "
+				"`rpcs3-spu-ffi` to expose the R7.1 surface).", spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// R7.2 — install the runtime DMA GET callback. The Rust
+		// interpreter invokes this on `wrch ch21 (MFC_Cmd)` with
+		// cmd=0x40, having already populated MFC_LSA / EAH / EAL /
+		// Size / TagID via the prior ch16-20 wrch's. The callback
+		// reads the EA bytes via RPCS3 `vm::_ptr<u8>` and copies them
+		// into the Rust handle's LS — the SPU continues end-to-end
+		// without any C++ fallback. Non-GET cmds and validation
+		// failures still produce MfcUnsupported, so the bridge falls
+		// back honestly for those.
+		if (rust_spu_set_dma_get_callback(h, &bridge_dma_get_callback, &spu) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_set_dma_get_callback failed "
+				"on '%s'; falling back to C++ executor (R7.1 honest-fallback path will "
+				"still trigger, but R7.2 runtime DMA path is unavailable).", spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// R8.1 — install the runtime DMA PUT callback. Symmetric to
+		// R7.2 GET but inverts the direction: SPU produces LS bytes
+		// during prior interpreter steps; callback memcpys them to
+		// RPCS3 EA via vm::_ptr<u8>. Both GET and PUT callbacks are
+		// installed so any single wrch ch21 dispatches to the right
+		// one based on the cmd value (0x40 GET / 0x20 PUT). List
+		// cmds, atomics, barriers, etc. surface MfcUnsupported and
+		// fall back to C++.
+		if (rust_spu_set_dma_put_callback(h, &bridge_dma_put_callback, &spu) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_set_dma_put_callback failed "
+				"on '%s'; falling back to C++ executor (R8.1 PUT path unavailable).",
+				spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// R8.4d — install the runtime DMA GETL callback. GETL is a
+		// list-DMA: a single wrch ch21 (cmd=0x44) instructs the MFC to
+		// walk an array of 8-byte BE descriptors in SPU LS at
+		// `descriptor_lsa = mfc_eal & 0x3fff8`, with `descriptor_size`
+		// = N * 8. Each slot has u8 sb, u8 pad, be_u16 ts, be_u32 ea.
+		// For each element the callback memcpys `ts` bytes from
+		// RPCS3 EA (via vm::_ptr<u8>) into Rust LS at
+		// `lsa_dest_base + cumulative_offset` (no padding-up — raw ts
+		// sum). Tag-stat is queued atomically after the whole list
+		// succeeds. Stall-and-notify (sb bit 0x80) is out of scope and
+		// rejected, so the bridge falls back honestly to C++ for that.
+		// PUTL / GETLB / GETLF are not handled and surface
+		// MfcUnsupported.
+		if (rust_spu_set_dma_getl_callback(h, &bridge_dma_getl_callback, &spu) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_set_dma_getl_callback failed "
+				"on '%s'; falling back to C++ executor (R8.4d GETL path unavailable).",
+				spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// R8.4e -- install the runtime DMA PUTL callback. PUTL is
+		// the symmetric inverse of GETL: same descriptor format in
+		// LS, but each element copies `ts` bytes FROM Rust LS at
+		// `lsa_src_base + cumulative_offset` TO RPCS3 EA via
+		// `vm::_ptr<u8>(ea)`. Same per-element validation envelope
+		// (`sb & 0x80 == 0`, `ts > 0`, `ts <= 0x4000`, cumulative
+		// LS within 256 KiB, vm::_ptr accessible). Tag-stat is
+		// queued atomically after the whole list succeeds.
+		// PUTLB / PUTLF / GETLB / GETLF are not handled and surface
+		// MfcUnsupported.
+		if (rust_spu_set_dma_putl_callback(h, &bridge_dma_putl_callback, &spu) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_set_dma_putl_callback failed "
+				"on '%s'; falling back to C++ executor (R8.4e PUTL path unavailable).",
+				spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// Load the full 256 KiB Local Store image.
+		if (rust_spu_load_ls(h, spu.ls, SPU_LS_SIZE) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_load_ls failed on '%s'; "
+				"falling back to C++ executor", spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// Set entry PC.
+		if (rust_spu_set_pc(h, spu.pc) != 0)
+		{
+			spu_rust_bridge_log.warning(
+				"[Rust SPU bridge] try_delegate: rust_spu_set_pc(0x%x) failed on '%s'; "
+				"falling back to C++ executor", spu.pc, spu.get_name());
+			rust_spu_drop(h);
+			return false;
+		}
+
+		// Mirror all 128 GPRs. SPU `main(spu_id, arg)` ABI puts
+		// `spu_id` in r3 and `arg` in r4; pulling the full bank is
+		// future-proof and costs ~2 KiB per delegation (negligible).
+		for (u32 r = 0; r < 128; ++r)
+		{
+			u8 bytes[16];
+			v128_to_be_bytes(spu.gpr[r], bytes);
+			if (rust_spu_set_gpr(h, r, bytes) != 0)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: rust_spu_set_gpr(r%u) failed on '%s'; "
+					"falling back to C++ executor", r, spu.get_name());
+				rust_spu_drop(h);
+				return false;
+			}
+		}
+
+		// Hand the handle to the side-table (RAII ownership). All
+		// subsequent paths reference `session->handle` and use
+		// `drop_session(spu.lv2_id)` to release.
+		BridgeSession* session = insert_session(spu.lv2_id, h);
+
+		spu_rust_bridge_log.trace(
+			"[Rust SPU bridge] SESSION CREATED for lv2_id=0x%x", spu.lv2_id);
+
+		// =========================================================
+		// Phase 1 — IN_MBOX peek + push to Rust.
+		// `try_read` is non-destructive, so we can fall back without
+		// disturbing RPCS3's mailbox state.
+		// =========================================================
+
+		u32 in_vals[4] = {0, 0, 0, 0};
+		u32 in_count = spu.ch_in_mbox.try_read(in_vals);
+
+		for (u32 i = 0; i < in_count; ++i)
+		{
+			if (rust_spu_push_inmbox(h, in_vals[i]) != 0)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: rust_spu_push_inmbox failed on '%s'; "
+					"falling back to C++ executor", spu.get_name());
+				drop_session(spu.lv2_id);
+				return false;
+			}
+		}
+
+		// =========================================================
+		// Phase 1b — SNR1 / SNR2 peek + forward to Rust (R6.3c).
+		// Same non-destructive pattern: `spu_channel::try_read` reads
+		// the pending value without consuming it. SNR forwarding goes
+		// through `rust_spu_signal(slot, value)`. RPCS3's `ch_snr1`/
+		// `ch_snr2` already hold the OR-merged value the PPU sent via
+		// `sysSpuThreadWriteSignal`, so we forward that single value;
+		// the Rust side OR-merges as well, matching Cell BE semantics.
+		// =========================================================
+
+		u32 snr1_value = 0;
+		u32 snr2_value = 0;
+		bool snr1_pending = spu.ch_snr1.try_read(snr1_value);
+		bool snr2_pending = spu.ch_snr2.try_read(snr2_value);
+		u32 signals_forwarded = 0;
+
+		if (snr1_pending)
+		{
+			if (rust_spu_signal(h, /*slot=*/0u, snr1_value) != 0)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: rust_spu_signal(SNR1=0x%x) failed on '%s'; "
+					"falling back to C++ executor", snr1_value, spu.get_name());
+				drop_session(spu.lv2_id);
+				return false;
+			}
+			signals_forwarded++;
+			session->snr1_forwarded = true;
+		}
+
+		if (snr2_pending)
+		{
+			if (rust_spu_signal(h, /*slot=*/1u, snr2_value) != 0)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: rust_spu_signal(SNR2=0x%x) failed on '%s'; "
+					"falling back to C++ executor", snr2_value, spu.get_name());
+				drop_session(spu.lv2_id);
+				return false;
+			}
+			signals_forwarded++;
+			session->snr2_forwarded = true;
+		}
+
+		// =========================================================
+		// Phase 2 — multi-round run loop (R6.4b).
+		//
+		// Strategy:
+		//   - Run up to `kMaxSteps` Rust SPU instructions per call.
+		//   - On `Stop`: break out of the loop, fall through to commit.
+		//   - On `StallRead` of a *supported* channel (IN_MBOX, SNR1,
+		//     SNR2): block on the corresponding RPCS3 channel via
+		//     `pop_wait` (matches the C++ executor pattern in
+		//     `spu_thread::get_ch_value`). When the PPU pushes a value
+		//     and `pop_wait` returns, forward the popped value into the
+		//     Rust handle and continue the loop. This is destructive
+		//     on the RPCS3 side, so the bridge is "all-in" once the
+		//     loop enters this branch — but `pop_wait` is exactly what
+		//     C++ would have done at the same SPU PC, and the only
+		//     way the Rust executor can lose the popped value
+		//     afterward is by hitting `Error` (unsupported opcode),
+		//     which is documented as a known edge case.
+		//   - On unsupported `Stall*` / `Continue` / `Error`: drop
+		//     the session, fall back to C++ — RPCS3 state is intact
+		//     unless we already pop_wait'd, in which case the values
+		//     are lost (logged at WARNING). For the four R5.11/R5.11b
+		//     fixtures + the multi-round FFI test this never happens.
+		// =========================================================
+
+		constexpr u32 kMaxSteps = 1'000'000;
+		constexpr u32 kMaxStallIterations = 32;
+
+		u32 out_code = 0;
+		u32 out_steps = 0;
+		rust_spu_outcome_t outcome = rust_spu_outcome_t_Stop;
+
+		while (true)
+		{
+			outcome = rust_spu_run_until_event(h, kMaxSteps, &out_code, &out_steps);
+			session->total_steps += out_steps;
+
+			if (outcome == rust_spu_outcome_t_Stop)
+			{
+				break;
+			}
+
+			// Supported `StallRead`: pop_wait on the corresponding
+			// RPCS3 channel + push to Rust + continue.
+			if (outcome == rust_spu_outcome_t_StallRead &&
+				(out_code == 29u || out_code == 3u || out_code == 4u))
+			{
+				if (session->stall_iterations >= kMaxStallIterations)
+				{
+					spu_rust_bridge_log.warning(
+						"[Rust SPU bridge] try_delegate: max stall iterations (%u) reached on '%s'; "
+						"dropping session and falling back to C++ executor. "
+						"This indicates either a runaway stall loop in the SPU program or a "
+						"bridge bookkeeping bug.",
+						kMaxStallIterations, spu.get_name());
+					drop_session(spu.lv2_id);
+					return false;
+				}
+
+				const StallClass cls = classify_stall_channel(out_code);
+				spu_rust_bridge_log.trace(
+					"[Rust SPU bridge] PARKED on %s (stall iter %u, total steps %u) on '%s'; "
+					"blocking on RPCS3 channel via pop_wait",
+					cls.name, session->stall_iterations + 1, session->total_steps,
+					spu.get_name());
+
+				session->stall_iterations++;
+
+				// Block on RPCS3 channel. Same path the C++ executor
+				// takes in `spu_thread::get_ch_value`.
+				if (out_code == 29u)
+				{
+					// IN_MBOX (4-deep queue). `pop_wait` returns
+					// {old_count, value}. old_count==0 indicates
+					// abort (e.g. SPU thread stopping).
+					const auto popped = spu.ch_in_mbox.pop_wait(spu, /*pop_value=*/true);
+					if (popped.first == 0)
+					{
+						spu_rust_bridge_log.warning(
+							"[Rust SPU bridge] try_delegate: IN_MBOX pop_wait aborted on '%s' "
+							"(SPU thread stopping?); dropping session and falling back",
+							spu.get_name());
+						drop_session(spu.lv2_id);
+						return false;
+					}
+					if (rust_spu_push_inmbox(h, popped.second) != 0)
+					{
+						spu_rust_bridge_log.warning(
+							"[Rust SPU bridge] try_delegate: post-stall rust_spu_push_inmbox "
+							"failed on '%s'; dropping session", spu.get_name());
+						drop_session(spu.lv2_id);
+						return false;
+					}
+					session->in_mbox_consumed++;
+					spu_rust_bridge_log.trace(
+						"[Rust SPU bridge] WAKE on IN_MBOX value=0x%x on '%s'", popped.second, spu.get_name());
+				}
+				else
+				{
+					// SNR1 / SNR2 (depth-1 spu_channel). `pop_wait`
+					// returns s64 — high bits carry error sentinel.
+					spu_channel& ch = (out_code == 3u) ? spu.ch_snr1 : spu.ch_snr2;
+					const u32 slot = (out_code == 3u) ? 0u : 1u;
+					const s64 result = ch.pop_wait(spu);
+					if (result < 0)
+					{
+						spu_rust_bridge_log.warning(
+							"[Rust SPU bridge] try_delegate: SNR%u pop_wait aborted on '%s'; "
+							"dropping session and falling back",
+							(slot + 1u), spu.get_name());
+						drop_session(spu.lv2_id);
+						return false;
+					}
+					const u32 sig_value = static_cast<u32>(result);
+					if (rust_spu_signal(h, slot, sig_value) != 0)
+					{
+						spu_rust_bridge_log.warning(
+							"[Rust SPU bridge] try_delegate: post-stall rust_spu_signal(SNR%u=0x%x) "
+							"failed on '%s'; dropping session",
+							(slot + 1u), sig_value, spu.get_name());
+						drop_session(spu.lv2_id);
+						return false;
+					}
+					if (slot == 0u) session->snr1_forwarded = true;
+					else            session->snr2_forwarded = true;
+					signals_forwarded++;
+					spu_rust_bridge_log.trace(
+						"[Rust SPU bridge] WAKE on SNR%u value=0x%x on '%s'",
+						(slot + 1u), sig_value, spu.get_name());
+				}
+				// Continue the loop — re-run on the same handle.
+				continue;
+			}
+
+			// R6.5b — Supported `StallWrite` on OUT_MBOX (ch28).
+			// The Rust executor's OUT_MBOX is depth-1 (`Option<u32>`),
+			// matching Cell BE semantics: a second `wrch ch28` while
+			// the first is still pending parks. The bridge's
+			// resolution: drain the pending value into RPCS3's
+			// `ch_out_mbox` (depth-1) via `set_value`. This is
+			// destructive — any pre-existing value in RPCS3's channel
+			// is overwritten. In PSL1GHT cooperative-thread context
+			// the PPU has no syscall to read OUT_MBOX during execution
+			// (only the lv2 stop-handler reads it as exit_status), so
+			// intermediate values are functionally lost regardless;
+			// the depth-1 overwrite IS the semantic. After draining
+			// we re-run the same handle; the SPU's stalled `wrch`
+			// retries against an empty Rust mailbox and succeeds.
+			if (outcome == rust_spu_outcome_t_StallWrite && out_code == 28u)
+			{
+				if (session->stall_write_iterations >= kMaxStallIterations)
+				{
+					spu_rust_bridge_log.warning(
+						"[Rust SPU bridge] try_delegate: max StallWrite iterations (%u) reached on '%s'; "
+						"dropping session and falling back to C++ executor. "
+						"This indicates either a SPU runaway-write loop or a backpressure "
+						"deadlock that the depth-1 overwrite resolution cannot break.",
+						kMaxStallIterations, spu.get_name());
+					drop_session(spu.lv2_id);
+					return false;
+				}
+
+				const StallClass cls = classify_stall_channel(out_code);
+				spu_rust_bridge_log.trace(
+					"[Rust SPU bridge] PARKED on %s (StallWrite, write iter %u, total steps %u) on '%s'; "
+					"draining intermediate value from Rust OUT_MBOX into RPCS3 (depth-1 overwrite)",
+					cls.name, session->stall_write_iterations + 1, session->total_steps,
+					spu.get_name());
+
+				session->stall_write_iterations++;
+
+				// Pop the value blocking Rust's OUT_MBOX.
+				u32 intermediate = 0;
+				if (rust_spu_pop_outmbox(h, &intermediate) != 0)
+				{
+					// Should be unreachable: Rust just told us OUT_MBOX is full.
+					spu_rust_bridge_log.warning(
+						"[Rust SPU bridge] try_delegate: StallWrite ch28 but rust_spu_pop_outmbox "
+						"returned empty on '%s'; dropping session and falling back",
+						spu.get_name());
+					drop_session(spu.lv2_id);
+					return false;
+				}
+
+				// Push to RPCS3's depth-1 ch_out_mbox. set_value overwrites
+				// any prior value — matches the PSL1GHT-cooperative reality
+				// that intermediate OUT_MBOX writes the PPU never observes.
+				spu.ch_out_mbox.set_value(intermediate);
+
+				spu_rust_bridge_log.trace(
+					"[Rust SPU bridge] WAKE on OUT_MBOX intermediate=0x%x set on RPCS3 ch_out_mbox on '%s'",
+					intermediate, spu.get_name());
+
+				// Continue the loop — Rust's OUT_MBOX is now empty, the
+				// stalled `wrch` will retry on the next run_until_event.
+				continue;
+			}
+
+			// Any other outcome (unsupported Stall, Continue, Error,
+			// or future variant): drop session, fall back honestly.
+			break;
+		}
+
+		if (outcome != rust_spu_outcome_t_Stop)
+		{
+			// Detailed classification of the non-Stop, non-supported-stall
+			// outcome that broke us out of the loop.
+			switch (outcome)
+			{
+			case rust_spu_outcome_t_StallRead:
+			case rust_spu_outcome_t_StallWrite:
+			{
+				const StallClass cls = classify_stall_channel(out_code);
+				const char* dir = (outcome == rust_spu_outcome_t_StallRead) ? "read" : "write";
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: %s stall on %s during %s "
+					"(stall_iters=%u total_steps=%u) on '%s'. %s — dropping session and "
+					"falling back to C++ executor",
+					outcome_name(outcome), cls.name, dir,
+					session->stall_iterations, session->total_steps, spu.get_name(),
+					cls.potentially_retryable
+						? "Re-tryable channel — but R6.4b only handles StallRead on mailbox/SNR; "
+						  "StallWrite (e.g. OUT_MBOX backpressure) lands in R6.4c+"
+						: "Not re-tryable in R6.4 scope (event/decrementer/DMA class)");
+				break;
+			}
+			case rust_spu_outcome_t_Continue:
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: Continue (max_steps=%u budget exhausted) "
+					"on '%s' after %u total steps; dropping session and falling back to C++ "
+					"executor (workload exceeds bridge budget; longer-running workloads need "
+					"R6.4c+ multi-call session support).",
+					kMaxSteps, spu.get_name(), session->total_steps);
+				break;
+			case rust_spu_outcome_t_Error:
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: Error at PC=0x%x total_steps=%u on '%s'; "
+					"dropping session and falling back to C++ executor (unsupported opcode "
+					"or LS-OOB; the C++ recompilers cover a wider opcode set than the Rust "
+					"subset). %s",
+					out_code, session->total_steps, spu.get_name(),
+					session->in_mbox_consumed > 0 || session->snr1_forwarded || session->snr2_forwarded
+						? "WARNING: this session already pop_wait'd RPCS3 channel values — those "
+						  "values are now lost; C++ executor will see partially-drained channels "
+						  "and may diverge from a clean run."
+						: "Channel state intact (no destructive ops performed before Error).");
+				break;
+			case rust_spu_outcome_t_MfcUnsupported:
+			{
+				// R7.1 — honest fallback. The Rust executor refused
+				// `wrch ch{16..23}` / `rdch ch{24,25}` / `rchcnt` on
+				// any of those BEFORE mutating per-channel state.
+				// Runtime DMA execution is R7.2 scope (Phase D); for
+				// now we always hand off to the C++ executor.
+				//
+				// Important state-correctness invariant: the Rust
+				// handle owns its own LS/GPR/channels copy that was
+				// initialised from RPCS3 at delegation start, and we
+				// have NOT synced it back to RPCS3 at any point along
+				// the fallback path. The C++ executor therefore
+				// resumes from RPCS3's untouched original state.
+				const char* mfc_kind =
+					(out_code <= 21) ? "MFC param/cmd wrch (ch16-21)" :
+					(out_code == 22) ? "MFC_WrTagMask (ch22)" :
+					(out_code == 23) ? "MFC_WrTagUpdate (ch23)" :
+					(out_code == 24) ? "MFC_RdTagStat (ch24)" :
+					(out_code == 25) ? "MFC_RdTagMask (ch25)" :
+					"MFC range (out-of-spec)";
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: MFC/DMA detected at ch%u (%s), "
+					"total_steps=%u on '%s'; falling back honestly to C++ executor "
+					"before Rust-side MFC mutation. Runtime DMA bridge is R7.2 scope; "
+					"%s",
+					out_code, mfc_kind, session->total_steps, spu.get_name(),
+					session->in_mbox_consumed > 0 || session->snr1_forwarded || session->snr2_forwarded
+						? "WARNING: this session already pop_wait'd RPCS3 channel values — "
+						  "those values are now lost; C++ executor will see partially-drained "
+						  "channels and may diverge from a clean run. (Pre-MFC channel "
+						  "activity is unusual for a pure DMA workload; investigate.)"
+						: "Channel state intact (no destructive ops performed before MFC refusal).");
+				break;
+			}
+			default:
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: unexpected outcome=%s code=0x%x on '%s'; "
+					"dropping session and falling back to C++ executor",
+					outcome_name(outcome), out_code, spu.get_name());
+				break;
+			}
+			drop_session(spu.lv2_id);
+			return false;
+		}
+
+		// =========================================================
+		// Phase 3 — Stop reached. Commit to delegation.
+		// We now mutate RPCS3 state: drain RPCS3's IN_MBOX (which we
+		// peeked earlier — `in_count` from the initial peek were
+		// pushed to Rust; any ADDITIONAL values consumed via pop_wait
+		// inside the loop were already popped from RPCS3 there, so
+		// only the original `in_count` need draining now), publish
+		// OUT_MBOX, sync PC + GPRs, then invoke stop_and_signal(code)
+		// so the rest of RPCS3 (group join, status_npc, exit_status)
+		// terminates exactly as the C++ executor would.
+		// =========================================================
+
+		// Drain RPCS3's IN_MBOX: the Rust SPU consumed `in_count`
+		// values during run from our initial peek. Note the loop body
+		// above already pop_wait'd anything that arrived AFTER the
+		// initial peek — those are not in RPCS3's queue anymore.
+		{
+			u32 drained = 0;
+			for (u32 i = 0; i < in_count; ++i)
+			{
+				u32 v = 0;
+				if (!spu.ch_in_mbox.try_pop(v))
+				{
+					break;
+				}
+				drained++;
+			}
+			if (drained != in_count)
+			{
+				spu_rust_bridge_log.warning(
+					"[Rust SPU bridge] try_delegate: IN_MBOX drained %u/%u entries; "
+					"continuing — discrepancy is non-fatal", drained, in_count);
+			}
+		}
+
+		// R6.3c — drain SNR1 / SNR2 channels we forwarded to Rust
+		// from the *initial* peek. Loop-body pop_wait'd values are
+		// already consumed.
+		if (snr1_pending)
+		{
+			u32 dummy = 0;
+			spu.ch_snr1.try_pop(dummy);
+		}
+		if (snr2_pending)
+		{
+			u32 dummy = 0;
+			spu.ch_snr2.try_pop(dummy);
+		}
+
+		// Publish OUT_MBOX. The Rust executor's mailbox is a queue;
+		// RPCS3's `ch_out_mbox` is a depth-1 channel. Multi-round
+		// fixtures may emit several values; we keep the LATEST
+		// (matching depth-1 channel overwrite semantics).
+		{
+			u32 out_val = 0;
+			u32 popped = 0;
+			while (rust_spu_pop_outmbox(h, &out_val) == 0)
+			{
+				popped++;
+			}
+			if (popped > 0)
+			{
+				spu.ch_out_mbox.set_value(out_val);
warning: in the working copy of 'rpcs3/Emu/Cell/SPURustBridge.h', LF will be replaced by CRLF the next time Git touches it
+				if (popped > 1)
+				{
+					spu_rust_bridge_log.warning(
+						"[Rust SPU bridge] try_delegate: %u OUT_MBOX values "
+						"in Rust handle; RPCS3 channel is depth-1, kept latest "
+						"(0x%x). Multi-write workloads need R6.4c+ to drain "
+						"OUT_MBOX between writes.",
+						popped, out_val);
+				}
+			}
+		}
+
+		// Sync the final PC + GPRs back into spu_thread. This makes
+		// post-stop RPCS3-side hooks (final_state trace guard, etc.)
+		// see exactly what the Rust executor produced.
+		{
+			u32 final_pc = 0;
+			if (rust_spu_get_pc(h, &final_pc) == 0)
+			{
+				spu.pc = final_pc;
+			}
+		}
+		for (u32 r = 0; r < 128; ++r)
+		{
+			u8 bytes[16];
+			if (rust_spu_get_gpr(h, r, bytes) != 0)
+			{
+				continue;
+			}
+			// Inverse of v128_to_be_bytes: bytes[i*4..i*4+3] BE -> _u32[3-i].
+			v128 v{};
+			for (u32 i = 0; i < 4; ++i)
+			{
+				const u32 w =
+					(static_cast<u32>(bytes[i * 4 + 0]) << 24) |
+					(static_cast<u32>(bytes[i * 4 + 1]) << 16) |
+					(static_cast<u32>(bytes[i * 4 + 2]) << 8) |
+					(static_cast<u32>(bytes[i * 4 + 3]) << 0);
+				v._u32[3 - i] = w;
+			}
+			spu.gpr[r] = v;
+		}
+
+		spu_rust_bridge_log.success(
+			"[Rust SPU bridge] DELEGATED EXECUTION OK on '%s' (lv2_id=0x%x): "
+			"Stop code=0x%x total_steps=%u in_mbox_consumed=%u signal_forwarded=%u "
+			"stall_iters=%u stall_write_iters=%u final_pc=0x%x. Routing through stop_and_signal() now.",
+			spu.get_name(), spu.lv2_id, out_code, session->total_steps,
+			(in_count + session->in_mbox_consumed), signals_forwarded,
+			session->stall_iterations, session->stall_write_iterations, spu.pc);
+
+		// Drop the session (RAII calls `rust_spu_drop` on the handle).
+		drop_session(spu.lv2_id);
+
+		// Hand off to RPCS3's existing stop machinery — this sets
+		// cpu_flag::stop / cpu_flag::ret, pops the OUT_MBOX value into
+		// group->exit_status (for code 0x101), and signals join
+		// waiters. After this returns, cpu_task() will see the stop
+		// flag and exit the run loop.
+		spu.stop_and_signal(out_code);
+		return true;
+#else
+		(void)spu;
+		return false;
+#endif
+	}
+}
