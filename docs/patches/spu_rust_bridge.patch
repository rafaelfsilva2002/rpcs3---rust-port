+++ b/rpcs3/Emu/Cell/SPURustBridge.h
@@ -0,0 +1,231 @@
+#pragma once
+
+// R6.1 / R6.2 / R6.3a / R6.3b / R6.3c / R6.4a / R6.4b / R6.5b / R7.1 / R7.2 / R8.1 / R8.4d / R8.4e — RPCS3 ↔ Rust SPU bridge (opt-in, default OFF).
+//
+// This header is the C++-side facade over the `rpcs3_spu_ffi` Rust
+// staticlib. It lets the SPU thread loop optionally delegate
+// execution to the pure-Rust SPU executor (interpreter +
+// recompiler) once the env var RPCS3_SPU_RUST_BRIDGE=1 is set.
+//
+// R6.1 scope: hello-world ONLY — proves the staticlib links and the
+// FFI surface is callable.
+// R6.2 scope: first DELEGATED execution path. The bridge can take
+// over execution of a single SPU thread for mailbox-only Stop-
+// terminating workloads. Implementation is deliberately generic:
+// no fixture-specific eligibility check — the bridge runs the SPU
+// to its first event (Stop / Stall / Continue / Error) and then
+// either commits (on Stop) or falls back honestly (every other
+// outcome). RPCS3 state stays untouched on the fallback path.
+// R6.3a scope: same generic implementation now exercised end-to-end
+// on a second oracle fixture, `single_spu_branch_loop_v1`. The
+// bridge runs the Fibonacci loop (~70 SPU instructions) and exits
+// via the same `stop_and_signal(0x101)` path. No code changes
+// were needed.
+// R6.3b scope: third delegated fixture, `single_spu_loadstore_v1`,
+// confirms the bridge's LS/PC/GPR sync (including r1 stack pointer
+// preservation) and the Rust executor's stqd/lqd quadword load/
+// store opcodes. ~187 SPU instructions including a real LS round-
+// trip via volatile stack buffer; OUT_MBOX = 0x81C. Again, no
+// bridge logic changes — only proof + log/doc updates.
+// R6.3c scope: fourth delegated fixture, `single_spu_signal_v1`,
+// adds SNR1 / SNR2 forwarding (the FIRST real bridge logic
+// extension since R6.2). The PPU sends a signal via
+// `sysSpuThreadWriteSignal` which lands in `spu_thread::ch_snr1`
+// or `ch_snr2`. The bridge non-destructively peeks (`try_read`)
+// these channels before run, forwards via `rust_spu_signal(slot,
+// value)` (slot=0 for SNR1, slot=1 for SNR2), and only consumes
+// the RPCS3-side channel via `try_pop` on the Stop-commit branch.
+//
+// R6.4a scope: formalize the outcome contract + classification.
+// `try_delegate_execution()` returns true ONLY for
+// `RustSpuOutcome::Stop`; every other outcome (Continue / StallRead
+// / StallWrite / Error) falls back to the C++ executor with the
+// load-bearing invariant that RPCS3 state is byte-identical to
+// entry on the fallback path:
+//   - PC, GPRs, LS unchanged (Phase 0 only reads).
+//   - IN_MBOX peeked via `try_read` (non-destructive).
+//   - SNR1/SNR2 peeked via `try_read` (non-destructive).
+//   - OUT_MBOX, ch_in_mbox, ch_snr*, ch_out_mbox not mutated.
+//   - `stop_and_signal()` not invoked.
+// On Stop the bridge commits exactly once: drains the channels
+// it peeked, publishes OUT_MBOX, syncs PC + 128 GPRs, and routes
+// through `stop_and_signal(out_code)` so RPCS3's existing group-
+// exit machinery handles the rest.
+//
+// The R6.4a fallback log includes:
+//   - For StallRead/StallWrite: the channel name (mapped via
+//     `classify_stall_channel`) and a re-tryability flag.
+//     Mailbox/Signal channels (28/29/3/4) are flagged re-tryable;
+//     event/decrementer/DMA channels are not.
+//   - For Continue: the per-call max_steps budget (1M).
+//   - For Error: the failing PC.
+//
+// R6.5b — StallWrite OUT_MBOX (ch28) handling. The multi-round
+// loop now also handles `StallWrite code=28` by popping the
+// pending value out of Rust's depth-1 OUT_MBOX, calling
+// `set_value` on RPCS3's `ch_out_mbox` (which is also depth-1, so
+// any pre-existing value is overwritten), and resuming the same
+// handle. This is the correct semantic for PSL1GHT cooperative
+// SPU threads: there is no syscall path for the PPU to read a
+// cooperative SPU's OUT_MBOX during execution, so intermediate
+// writes the PPU cannot observe are FUNCTIONALLY lost regardless;
+// the depth-1 overwrite IS the well-defined semantic. A separate
+// `stall_write_iterations` counter mirrors `stall_iterations`,
+// and both are surfaced in the DELEGATED success log. A real-
+// binary fixture cannot exercise this path (a SPU that writes
+// OUT_MBOX twice with neither overlapping a stop instruction
+// would deadlock the C++ executor's `push_wait` since PSL1GHT
+// can't drain) — the FFI-level acceptance gate is
+// `rust_spu_outmbox_backpressure_via_ffi`.
+//
+// R6.4b — persistent-handle multi-round loop. The bridge now keeps
+// a `BridgeSession` (in a side-table keyed by `spu_thread::lv2_id`)
+// alive across `rust_spu_run_until_event` calls within a single
+// `try_delegate_execution`. On `StallRead` of a supported channel
+// (29 IN_MBOX, 3 SNR1, 4 SNR2) the bridge calls the corresponding
+// RPCS3-side `pop_wait` (the same path the C++ executor uses in
+// `spu_thread::get_ch_value`), forwards the popped value into the
+// Rust handle, and re-runs. This makes multi-round mailbox/SNR
+// fixtures delegate end-to-end. The session is dropped on Stop
+// commit, on unsupported outcomes, on stall-iteration cap, or on
+// `Error` (drop also triggers `rust_spu_drop`). The side-table
+// supports cross-call session survival as a future R6.4c
+// extensibility hook, but R6.4b sessions never outlive a single
+// `try_delegate_execution` call. The FFI-level acceptance gate
+// is `rust_spu_mailbox_multi_round_via_ffi` (in
+// `rust/rpcs3-spu-ffi/src/tests.rs`); a real-binary acceptance
+// gate via `single_spu_mailbox_multi_v1.self` lands when PSL1GHT
+// is available (R6.4b-pre authored the source).
+//
+// Verified workloads: `single_spu_mailbox_v1`,
+// `single_spu_branch_loop_v1`, `single_spu_loadstore_v1`,
+// `single_spu_signal_v1`. Other fixtures and game workloads
+// still fall back honestly.
+//
+// R7.1 scope: honest fallback for MFC/DMA workloads. On every
+// `rust_spu_new` we call `rust_spu_set_refuse_mfc(handle, 1)`.
+// Without R7.2's callback installed, this makes any MFC channel op
+// surface `rust_spu_outcome_t_MfcUnsupported` BEFORE per-channel
+// mutation; the outer switch logs "MFC/DMA detected at ch%u, ...
+// falling back honestly to C++ executor before Rust-side MFC
+// mutation" and drops the session. R7.1 verified on
+// `single_spu_dma_get_v1.self` with the callback uninstalled.
+//
+// R7.2 scope: runtime DMA GET execution. On every `rust_spu_new`
+// we ALSO call `rust_spu_set_dma_get_callback(handle,
+// &bridge_dma_get_callback, &spu)`. The callback reads `size`
+// bytes from RPCS3 EA `eal` via `vm::_ptr<u8>` (the same path the
+// C++ executor's `process_mfc_cmd()` simple-GET branch uses) and
+// memcpys them into the Rust handle's LS at `mfc_lsa`. The Rust
+// interpreter validates cmd=0x40, eah=0, tag<32, size, and
+// lsa+size<=256 KiB before calling the callback, so unsupported
+// MFC ops (PUT, list, atomic, barriers, multi-SPU races) still
+// surface `MfcUnsupported` and the bridge falls back honestly to
+// the C++ executor for those.
+// Acceptance verified on `single_spu_dma_get_v1.self`: bridge ON
+// runs end-to-end through the Rust executor (no fallback at all),
+// produces `[dma_get_v1] OK cause=0x1 status=0xdeada12f` exactly
+// like bridge OFF, with `total_steps` ≈ the full SPU program
+// length (vs `total_steps=4` for the R7.1 R7.1-only path that
+// fell back at ch16).
+// PUT, list DMA, atomics, barriers, multi-SPU DMA / SPURS — out
+// of R7.2 scope; defer to R8+.
+//
+// R8.1 scope: runtime DMA PUT execution. Symmetric inverse of R7.2 —
+// `rust_spu_set_dma_put_callback(handle, &bridge_dma_put_callback,
+// &spu)` is installed at `rust_spu_new` time. On cmd=0x20 the
+// Rust interpreter validates eah/tag/size/lsa and calls the
+// callback, which memcpys `size` bytes from the Rust handle's LS
+// at `mfc_lsa` to RPCS3 EA `eal` via `vm::_ptr<u8>`. Acceptance
+// verified on `single_spu_dma_put_v1.self`: bridge ON delegates
+// end-to-end and produces the same EA sentinels as bridge OFF +
+// replay. List/atomic/barriers/multi-SPU still defer.
+//
+// R8.4d scope: runtime DMA GETL (list-GET) execution. List-DMA is
+// a single wrch ch21 with cmd=0x44 where `mfc_eal & 0x3fff8` points
+// at an array of 8-byte BE descriptors in SPU LS and
+// `mfc_size = N * 8` is the descriptor footprint. Each descriptor:
+// `u8 sb, u8 pad, be_u16 ts, be_u32 ea`. The bridge's
+// `bridge_dma_getl_callback` walks the descriptor array, and per
+// element memcpys `ts` bytes from RPCS3 EA (via `vm::_ptr<u8>`)
+// into Rust LS at `lsa_dest_base + cumulative_offset`, where
+// `cumulative_offset` advances by the raw `ts` sum (no padding-up,
+// per the Cell BE list-DMA contract). Tag-stat is queued atomically
+// after the whole list succeeds. Stall-and-notify (sb bit 0x80) is
+// rejected — falls back to C++ executor honestly. PUTLB / PUTLF /
+// GETLB / GETLF are not handled and surface `MfcUnsupported`.
+// Acceptance verified on `single_spu_dma_getl_v1.self` (the R8.4c
+// replay-validated 13th oracle): bridge ON delegates end-to-end
+// and produces canonical TTY `[dma_getl_v1] OK cause=0x1
+// status=0xdf1eea5a`, byte-identical to bridge OFF + replay.
+//
+// R8.4e scope: runtime DMA PUTL (list-PUT) execution. Symmetric
+// inverse of R8.4d. The bridge's `bridge_dma_putl_callback`
+// walks the same 8-byte BE descriptor array; each element memcpys
+// `ts` bytes FROM Rust LS at `lsa_src_base + cumulative_offset`
+// TO RPCS3 EA via `vm::_ptr<u8>(ea)`. `src_ls_ptr` is `const u8*`
+// (PUTL never mutates LS). Same per-element validation envelope
+// (sb&0x80, ts in (0, 0x4000], cumulative LS in 256 KiB, vm::_ptr
+// accessible); same atomic tag-stat queueing. PUTLB / PUTLF /
+// GETLB / GETLF / list stall-and-notify still rejected — out of
+// R8.4e scope; defer to R8.4f / R8.5+. Acceptance verified on
+// `single_spu_dma_putl_v1.self` (R8.4e 14th oracle):
+// bridge ON delegates end-to-end and produces canonical TTY
+// `[dma_putl_v1] OK cause=0x1 spu=0xc0ffeeba ea_status=0xa12fda7e`,
+// byte-identical to bridge OFF + replay.
+//
+// The whole bridge is compile-time gated by `RPCS3_HAS_SPU_RUST_BRIDGE`,
+// which the CMake build system sets only when the Rust staticlib
+// (`rust/target/release/rpcs3_spu_ffi.lib` or `.a`) is present.
+// If the staticlib has not been built, this header still compiles
+// and `is_enabled()` returns false unconditionally.
+//
+// See:
+//   - docs/R6_LIVE_BRIDGE_PLAN.md for the phased plan.
+//   - docs/SPU_RUST_BRIDGE_PATCH.md for build / apply instructions.
+//   - rust/rpcs3-spu-ffi/include/rpcs3_spu_ffi.h for the C ABI.
+
+class spu_thread;
+
+namespace spu_rust_bridge
+{
+	// Returns true iff the env var RPCS3_SPU_RUST_BRIDGE is exactly
+	// "1". Cached on first call; subsequent calls are lock-free.
+	// Always returns false if RPCS3_HAS_SPU_RUST_BRIDGE is not defined
+	// at compile time (i.e., the Rust staticlib was not present).
+	bool is_enabled();
+
+	// R6.1 hello-world: instantiates a `rust_spu_t*` handle, logs
+	// the activation, and drops it. Called at most ONCE per
+	// spu_thread (gated by a per-thread flag in the caller).
+	//
+	// On success: log via the `RustSPU` log channel at SUCCESS level.
+	// On failure (rust_spu_new returns null): log at ERROR level and
+	// return; the SPU thread continues with the existing C++
+	// executor.
+	void hello_world_proof(spu_thread& spu);
+
+	// R6.2 — try to delegate execution of `spu` to the Rust executor.
+	//
+	// On success (== returned `true`): the bridge has FULLY handled
+	// this SPU thread's execution up to a normal stop. Specifically:
+	//   - LS / PC / GPRs were copied into a Rust SPU handle
+	//   - any pending IN_MBOX values were forwarded
+	//   - `rust_spu_run_until_event` ran to a Stop outcome
+	//   - the resulting OUT_MBOX value was pushed back into RPCS3's
+	//     `ch_out_mbox` and `stop_and_signal(code)` was invoked,
+	//     setting the proper `cpu_flag::stop` / group join state.
+	// The caller MUST return from `cpu_task()` immediately; the SPU
+	// has terminated.
+	//
+	// On failure (== returned `false`): the bridge declined to handle
+	// this SPU thread (or hit an unsupported outcome). The caller
+	// MUST fall back to the existing C++ executor. RPCS3 state is
+	// guaranteed unchanged on failure — no GPRs written, no LS
+	// modified, IN_MBOX values restored if briefly drained, no
+	// stop_and_signal called. Reason is logged at WARNING level.
+	//
+	// Always returns false when `RPCS3_HAS_SPU_RUST_BRIDGE` is not
+	// defined or `is_enabled()` returns false.
+	bool try_delegate_execution(spu_thread& spu);
+}
