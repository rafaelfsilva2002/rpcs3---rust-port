+void TraceWriter::record_spu_park(std::uint32_t target_spu, std::uint32_t pc, ParkReason reason, std::uint32_t channel,
+	const std::optional<ChannelsSnapshot>& channels)
+{
+	if (!enabled()) return;
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "spu_park");
+	os << ",\"target_spu\":"; append_u32(os, target_spu);
+	os << ",\"pc\":";      append_u32(os, pc);
+	os << ",\"reason\":\"" << park_reason_str(reason) << '"';
+	os << ",\"channel\":"; append_u32(os, channel);
+	if (channels.has_value())
+	{
+		os << ",\"channels_at_park\":";
+		append_channels(os, *channels);
+	}
+	os << "}";
+	emit_line(os.str());
+}
