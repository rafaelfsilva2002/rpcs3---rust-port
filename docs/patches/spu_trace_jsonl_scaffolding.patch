+
+void TraceWriter::record_final_state(std::uint32_t target_spu, const std::vector<GprEntry>& gprs,
+	const ChannelsSnapshot& channels)
+{
+	if (!enabled()) return;
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "final_state");
+	os << ",\"target_spu\":"; append_u32(os, target_spu);
+	os << ",\"gpr_lane_zero\":[";
+	for (std::size_t i = 0; i < gprs.size(); ++i)
+	{
+		if (i > 0) os << ',';
+		os << "{\"reg\":";    append_u32(os, gprs[i].reg);
+		os << ",\"value\":";  append_u32(os, gprs[i].value);
+		os << "}";
+	}
+	os << "],\"channels\":";
+	append_channels(os, channels);
+	os << "}";
+	emit_line(os.str());
+}
+
+// R5.9e.3 — Capture the SPU's local-store image at thread entry, write a
+// content-addressed side-file, and emit a metadata-only JSONL event.
+// Per-target_spu dedup keeps the emit single-shot even on re-entered
+// `cpu_task`. Bytes are NEVER inlined in the JSONL.
+void TraceWriter::record_spu_image(std::uint32_t target_spu, const std::uint8_t* ls_bytes,
+	std::uint32_t size, std::uint32_t load_addr, std::uint32_t entry_pc)
+{
+	if (!enabled()) return;
+	if (!ls_bytes || size == 0)
+	{
+		// Defensive — caller error; would produce a zero-byte file
+		// hashing to a known well-formed sha but with no content.
+		// Drop the emit rather than corrupt the trace.
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_image dropped: ls_bytes=%p, size=%u\n",
+			static_cast<const void*>(ls_bytes), size);
+		return;
+	}
+
+	// Snapshot the LS bytes BEFORE taking the lock or computing the
+	// hash. The SPU may not yet be running (the documented contract),
+	// but a concurrent PPU-side DMA could in principle modify LS during
+	// the capture window. A local copy gives a stable view for both
+	// the SHA and the side-file write.
+	std::vector<std::uint8_t> snapshot(ls_bytes, ls_bytes + size);
+
+	// Compute SHA-256 of the snapshot. mbedtls is already linked into
+	// emucore (rpcs3/Crypto/sha256.cpp); using the existing utility
+	// avoids a bundled SHA implementation in this TU.
+	unsigned char hash[32];
+	if (mbedtls_sha256_ret(snapshot.data(), snapshot.size(), hash, /*is224=*/0) != 0)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_image dropped: mbedtls_sha256_ret failed for target_spu=%u\n",
+			target_spu);
+		return;
+	}
+
+	// Convert the 32-byte digest to a 64-char lowercase hex string,
+	// matching the schema's `image_sha256` format (R5.9e.1).
+	static constexpr char hex_chars[] = "0123456789abcdef";
+	char hex[65];
+	for (std::size_t i = 0; i < 32; ++i)
+	{
+		hex[i * 2]     = hex_chars[(hash[i] >> 4) & 0xF];
+		hex[i * 2 + 1] = hex_chars[hash[i] & 0xF];
+	}
+	hex[64] = '\0';
+	std::string sha256_hex(hex, 64);
+
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+
+	// Per-target_spu dedup pre-check: if this SPU already had a
+	// successful spu_image emit, the second invocation is a no-op.
+	// We only INSERT into the dedup set AFTER the side-file write
+	// succeeds — a failed write must not block a future retry.
+	if (m_emitted_images.find(target_spu) != m_emitted_images.end())
+	{
+		return;
+	}
+
+	// R5.9e.3-fix — Side-file write MUST succeed BEFORE the JSONL
+	// emit. The v4 bug was: the side-file write silently failed (no
+	// `<trace>.images/` directory created), but the JSONL `spu_image`
+	// event was emitted anyway, producing a trace whose
+	// `image_sha256` referenced a non-existent file. The schema
+	// (R5.9e.1 rule 8 — "no silent fallback") forbids this; the
+	// replay engine would later fail with `ImageFileMissing`. The
+	// fix bails out of the entire `record_spu_image` call when the
+	// write fails — neither the JSONL line nor the dedup-set
+	// insertion happen, so a subsequent call (e.g., from a re-
+	// entered `cpu_task`) gets to retry.
+	if (!write_image_side_file(sha256_hex, snapshot.data(), size))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_image dropped for target_spu=%u: side-file "
+			"write failed; JSONL spu_image NOT emitted (per R5.9e.1 rule 8)\n",
+			target_spu);
+		return;
+	}
+
+	// Side-file is on disk with the correct size. Now mark the SPU
+	// as emitted (so future calls dedup) AND emit the JSONL line.
+	m_emitted_images.insert(target_spu);
+
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "spu_image");
+	os << ",\"target_spu\":";   append_u32(os, target_spu);
+	os << ",\"image_sha256\":\"" << sha256_hex << '"';
+	os << ",\"load_addr\":";    append_u32(os, load_addr);
+	os << ",\"size\":";         append_u32(os, size);
+	os << ",\"entry_pc\":";     append_u32(os, entry_pc);
+	os << "}";
+	emit_line(os.str());
+}
+
+// R5.9e.3-fix — Returns true iff the side-file is on disk with the
+// expected size after the call. False on any failure path; caller
+// (`record_spu_image`) refuses to emit the JSONL line in that case
+// so the trace never references a missing/short file.
+bool TraceWriter::write_image_side_file(const std::string& sha256_hex,
+	const std::uint8_t* bytes, std::uint32_t size)
+{
+	if (m_trace_path.empty())
+	{
+		// Should never happen — the writer is only enabled when the
+		// constructor successfully captured the env var. Defensive.
+		std::fprintf(stderr,
+			"[spu_trace] write_image_side_file: m_trace_path is empty (writer state inconsistent)\n");
+		return false;
+	}
+
+	namespace fs = std::filesystem;
+	std::error_code ec;
+
+	// Side-file directory: `<trace_path>.images/`. Create on demand.
+	// `create_directories` returns true if it created anything new
+	// AND `ec` is unset; returns false (no-error) if the directory
+	// already exists; sets `ec` on permission/path failures. We treat
+	// "ec set" as failure, regardless of return value.
+	const fs::path images_dir = fs::path(m_trace_path).concat(".images");
+	fs::create_directories(images_dir, ec);
+	if (ec)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_image_side_file: create_directories('%s') failed: %s (errno-equivalent %d)\n",
+			images_dir.string().c_str(), ec.message().c_str(), ec.value());
+		return false;
+	}
+
+	// Sanity: the dir must exist and be a directory after the call.
+	// Defensive against silent no-op + missing directory cases that
+	// might arise on Windows with sandboxed FS access (the v4 bug
+	// symptom).
+	if (!fs::is_directory(images_dir, ec))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_image_side_file: '%s' is not a directory after create_directories (ec=%s)\n",
+			images_dir.string().c_str(), ec.message().c_str());
+		return false;
+	}
+
+	const fs::path file_path = images_dir / (sha256_hex + ".spuimg");
+
+	// Content-addressed dedup: if a file with the same SHA-named name
+	// already exists AND its size matches, assume content equality
+	// (SHA-256 is collision-resistant) and skip the rewrite. Returning
+	// true here is the load-bearing claim: "the side-file is on disk
+	// with the expected size".
+	if (fs::exists(file_path, ec))
+	{
+		ec.clear();
+		const auto existing_size = fs::file_size(file_path, ec);
+		if (!ec && existing_size == size)
+		{
+			return true;
+		}
+		// Existing file but size mismatch — overwrite below. Log so
+		// a future debugger can investigate if dedup ever produces
+		// surprising results.
+		std::fprintf(stderr,
+			"[spu_trace] write_image_side_file: '%s' exists with size %llu, expected %u — overwriting\n",
+			file_path.string().c_str(),
+			static_cast<unsigned long long>(existing_size), size);
+	}
+
+	{
+		std::ofstream of(file_path, std::ios::binary | std::ios::trunc);
+		if (!of.is_open())
+		{
+			std::fprintf(stderr,
+				"[spu_trace] write_image_side_file: ofstream open('%s', binary|trunc) failed\n",
+				file_path.string().c_str());
+			return false;
+		}
+		of.write(reinterpret_cast<const char*>(bytes), static_cast<std::streamsize>(size));
+		if (!of.good())
+		{
+			// `tellp()` reports how many bytes the ofstream believed
+			// it wrote before going bad. `gcount()` is istream-only.
+			const auto wrote = static_cast<long long>(of.tellp());
+			std::fprintf(stderr,
+				"[spu_trace] write_image_side_file: short/failed write to '%s' (wrote ~%lld of %u)\n",
+				file_path.string().c_str(), wrote, size);
+			return false;
+		}
+		of.flush();
+		// `of` closes on scope exit. Flush + close before the
+		// post-write size check so the on-disk size is final.
+	}
+
+	// Post-write verification: the file MUST exist with exactly
+	// `size` bytes after the close. This catches Windows quirks where
+	// the write appeared to succeed but the file was truncated by a
+	// concurrent file-system filter (antivirus, sandbox, etc.).
+	ec.clear();
+	const auto final_size = fs::file_size(file_path, ec);
+	if (ec)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_image_side_file: post-write file_size('%s') failed: %s\n",
+			file_path.string().c_str(), ec.message().c_str());
+		return false;
+	}
+	if (final_size != size)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_image_side_file: post-write size mismatch for '%s': on disk %llu, expected %u\n",
+			file_path.string().c_str(),
+			static_cast<unsigned long long>(final_size), size);
+		return false;
+	}
+
+	return true;
+}
+
