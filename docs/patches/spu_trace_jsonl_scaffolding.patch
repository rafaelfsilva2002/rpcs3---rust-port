+#include "stdafx.h"
+
+// R5.8 A.3 — SPU PPU↔SPU trace JSONL writer (impl).
+//
+// See SPUTraceJsonl.h for the public surface and `docs/SPU_TRACE_CAPTURE.md`
+// for the wire format. This translation unit is self-contained — it
+// has zero dependencies on RPCS3-internal types and could compile
+// standalone given a host with C++17 + the standard library.
+
+#include "SPUTraceJsonl.h"
+#include "Crypto/sha256.h"
+
+#include <cstdio>
+#include <cstdlib>
+#include <vector>
+#include <sstream>
+#include <iomanip>
+#include <string>
+#include <system_error>
+#include <filesystem>
+
+namespace rpcs3::spu_trace {
+
+// =====================================================================
+// Singleton lifecycle
+// =====================================================================
+
+TraceWriter& TraceWriter::instance()
+{
+	static TraceWriter inst;
+	return inst;
+}
+
+TraceWriter::TraceWriter()
+{
+	const char* path = std::getenv("RPCS3_SPU_TRACE_JSONL");
+	if (!path || path[0] == '\0')
+	{
+		// Disabled — every emit is a fast atomic-load short-circuit.
+		return;
+	}
+	m_file.open(path, std::ios::out | std::ios::trunc);
+	if (!m_file.is_open())
+	{
+		std::fprintf(stderr,
+			"[spu_trace] failed to open '%s' for writing — capture disabled\n",
+			path);
+		return;
+	}
+	// R5.9e.3 — record the trace path so `record_spu_image` can derive
+	// the side-file directory `<m_trace_path>.images/`. Only set when
+	// the writer is being enabled — the empty default disables side-
+	// file emission as a safety fallback.
+	m_trace_path.assign(path);
+	m_enabled.store(true, std::memory_order_release);
+	std::fprintf(stderr, "[spu_trace] capture enabled, output: %s\n", path);
+}
+
+TraceWriter::~TraceWriter()
+{
+	if (m_file.is_open())
+	{
+		m_file.flush();
+		m_file.close();
+	}
+}
+
+std::uint64_t TraceWriter::next_seq() noexcept
+{
+	return m_seq.fetch_add(1, std::memory_order_relaxed);
+}
+
+void TraceWriter::emit_line(std::string_view line)
+{
+	// Caller MUST hold m_write_mutex. The lock guards seq allocation,
+	// JSON formatting, and the actual write as a single critical section
+	// so on-disk line order matches seq allocation order. The original
+	// implementation took the lock here (after seq was already allocated
+	// in the caller's local scope) which allowed thread interleaving:
+	// thread A could allocate seq=N, thread B allocate seq=N+1, B reach
+	// the lock first and write seq=N+1, then A write seq=N — producing
+	// non-monotonic JSONL the Rust parser correctly rejected with
+	// `NonMonotonicSeq`. Locking the entire seq+format+write triple in
+	// the caller fixes the race.
+	if (!m_file.is_open())
+	{
+		return;
+	}
+	m_file.write(line.data(), static_cast<std::streamsize>(line.size()));
+	m_file.put('\n');
+	// No flush per line — OS buffer flushes on close. If the process
+	// crashes before exit the trace is truncated; that is acceptable
+	// because such a capture is uninteresting (the homebrew didn't
+	// reach final_state). For sync-flush, change to `m_file.flush();`.
+}
+
+// =====================================================================
+// JSON formatting helpers
+// =====================================================================
+//
+// Hand-rolled minimal serializer to avoid adding a JSON dep. The schema
+// only emits flat objects with primitive fields and a single nested
+// object (`channels` / `channels_at_park`) plus one array of small
+// objects (`gpr_lane_zero`). Fields are written in a stable order so
+// identical event content produces identical bytes — critical for diff
+// stability.
+
+namespace {
+
+void append_u32(std::ostringstream& os, std::uint32_t v) { os << v; }
+void append_u64(std::ostringstream& os, std::uint64_t v) { os << v; }
+
+void append_optional_u32(std::ostringstream& os, const std::optional<std::uint32_t>& v)
+{
+	if (v.has_value())
+	{
+		os << *v;
+	}
+	else
+	{
+		os << "null";
+	}
+}
+
+void append_bool(std::ostringstream& os, bool v) { os << (v ? "true" : "false"); }
+
+void append_channels(std::ostringstream& os, const ChannelsSnapshot& c)
+{
+	os << "{\"in_mbox\":";
+	append_optional_u32(os, c.in_mbox);
+	os << ",\"out_mbox\":";
+	append_optional_u32(os, c.out_mbox);
+	os << ",\"out_intr_mbox\":";
+	append_optional_u32(os, c.out_intr_mbox);
+	os << ",\"snr1\":";
+	append_u32(os, c.snr1);
+	os << ",\"snr2\":";
+	append_u32(os, c.snr2);
+	os << "}";
+}
+
+const char* park_reason_str(ParkReason r) noexcept
+{
+	return r == ParkReason::ChannelRead ? "channel_read" : "channel_write";
+}
+
+// Writes `"seq":<n>,"side":"<spu|ppu>","kind":"<kind>"` (no trailing
+// comma, no surrounding braces). Caller appends event-specific fields
+// then `}`.
+void start_event(std::ostringstream& os, std::uint64_t seq, bool spu_side,
+	std::string_view kind)
+{
+	os << "{\"seq\":" << seq
+	   << ",\"side\":\"" << (spu_side ? "spu" : "ppu") << '"'
+	   << ",\"kind\":\"" << kind << '"';
+}
+
+} // anonymous namespace
+
