+// =====================================================================
+// R6.7 A.1 — MFC DMA recorders
+// =====================================================================
+//
+// `record_spu_mfc_cmd` and `record_mfc_dma_complete` extend the writer
+// to capture the minimal MFC GET subset described in
+// `docs/SPU_DMA_MFC_R6_7_DESIGN.md` § 4. They are SPU-side recorders
+// (target_spu mandatory) and follow the same lock/seq/lock_guard
+// contract as every other `record_*` method.
+//
+// Side-file model mirrors `record_spu_image`: the EA bytes are written
+// to `<trace_path>.dma/<sha>.dmachunk`, content-addressed by SHA-256.
+// The JSONL `spu_mfc_cmd` line carries only the SHA pointer; bytes are
+// NEVER inlined. The replay engine resolves the SHA at parse time by
+// looking up `<trace>.dma/<sha>.dmachunk` (per-trace) or
+// `behavior-freeze/fixtures/spu/dma/<sha>.dmachunk` (canonical CC0
+// shared store) — same dual-path convention as `.spuimg`.
+
+void TraceWriter::record_spu_mfc_cmd(std::uint32_t target_spu, std::uint32_t pc,
+	std::uint32_t cmd, std::uint32_t tag, std::uint32_t size,
+	std::uint32_t lsa, std::uint32_t eah, std::uint32_t eal,
+	const std::uint8_t* ea_bytes, std::uint32_t ea_bytes_size)
+{
+	if (!enabled()) return;
+	if (!ea_bytes || ea_bytes_size == 0 || ea_bytes_size != size)
+	{
+		// Defensive — caller error. Drop the emit rather than write
+		// a `.dmachunk` whose size disagrees with the cmd's `size`
+		// field (the parser rejects with `DmaChunkSizeMismatch`).
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_cmd dropped: ea_bytes=%p, ea_bytes_size=%u, size=%u\n",
+			static_cast<const void*>(ea_bytes), ea_bytes_size, size);
+		return;
+	}
+
+	// Snapshot bytes BEFORE taking the lock or hashing. Caller MUST
+	// have already captured these from EA via vm::_ptr (RPCS3 vm::
+	// is not callable from inside the writer). We copy defensively
+	// to keep this function self-contained — the caller is free to
+	// release its snapshot vector after the call returns.
+	std::vector<std::uint8_t> snapshot(ea_bytes, ea_bytes + ea_bytes_size);
+
+	unsigned char hash[32];
+	if (mbedtls_sha256_ret(snapshot.data(), snapshot.size(), hash, /*is224=*/0) != 0)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_cmd dropped: mbedtls_sha256_ret failed for target_spu=%u tag=%u size=%u\n",
+			target_spu, tag, size);
+		return;
+	}
+
+	static constexpr char hex_chars[] = "0123456789abcdef";
+	char hex[65];
+	for (std::size_t i = 0; i < 32; ++i)
+	{
+		hex[i * 2]     = hex_chars[(hash[i] >> 4) & 0xF];
+		hex[i * 2 + 1] = hex_chars[hash[i] & 0xF];
+	}
+	hex[64] = '\0';
+	std::string sha256_hex(hex, 64);
+
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+
+	// Side-file MUST land before the JSONL emit (same contract as
+	// record_spu_image — refuse to emit a JSONL line that would
+	// reference a missing or short side-file).
+	if (!write_dma_chunk_side_file(sha256_hex, snapshot.data(), ea_bytes_size))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_cmd dropped for target_spu=%u tag=%u: "
+			"side-file write failed; JSONL spu_mfc_cmd NOT emitted\n",
+			target_spu, tag);
+		return;
+	}
+
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "spu_mfc_cmd");
+	os << ",\"target_spu\":"; append_u32(os, target_spu);
+	os << ",\"pc\":";         append_u32(os, pc);
+	os << ",\"cmd\":";        append_u32(os, cmd);
+	os << ",\"tag\":";        append_u32(os, tag);
+	os << ",\"size\":";       append_u32(os, size);
+	os << ",\"lsa\":";        append_u32(os, lsa);
+	os << ",\"eah\":";        append_u32(os, eah);
+	os << ",\"eal\":";        append_u32(os, eal);
+	os << ",\"ea_chunk_sha256\":\"" << sha256_hex << '"';
+	os << "}";
+	emit_line(os.str());
+}
+
+// R8.4b — list-DMA recorder. Same general contract as
+// `record_spu_mfc_cmd` but with two side-file kinds:
+// `<sha>.dmalistdesc` for the descriptor array (one per cmd) and
+// `<sha>.dmachunk` for each element (REUSE of the existing pool;
+// deduplicates with simple GET/PUT chunks when patterns match).
+// JSONL emit is dropped if any side-file write fails — caller
+// MUST skip the subsequent `record_mfc_dma_complete` if so.
+//
+// R8.4e: now also accepts cmd=0x24 PUTL (symmetric LS → EA). The
+// wire format is identical (same fields, same .dmalistdesc /
+// .dmachunk side-files); only the byte direction differs. The
+// caller (SPUThread.cpp ch21 dispatch) is responsible for
+// providing the correct per-element source bytes — for GETL the
+// snapshots are pre-DMA EA reads (the source), for PUTL the
+// snapshots are pre-DMA LS reads (also the source). Receiver
+// (replay) infers direction from the `cmd` field.
+void TraceWriter::record_spu_mfc_getl_cmd(std::uint32_t target_spu, std::uint32_t pc,
+	std::uint32_t cmd, std::uint32_t tag,
+	std::uint32_t descriptor_size,
+	std::uint32_t lsa_dest_base,
+	std::uint32_t eah,
+	std::uint32_t descriptor_lsa,
+	const std::uint8_t* descriptor_bytes,
+	std::uint32_t element_count,
+	const std::uint8_t* const* element_chunks,
+	const std::uint32_t* element_sizes,
+	const std::uint32_t* element_eals)
+{
+	if (!enabled()) return;
+
+	// Defensive — caller error guards. R8.4b/c scope: cmd 0x44 GETL.
+	// R8.4e: also accepts cmd 0x24 PUTL. The runtime hook MUST
+	// filter; the wire format is identical between directions.
+	if (cmd != 0x44u && cmd != 0x24u)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_getl_cmd dropped: cmd=0x%x is not 0x44 GETL or 0x24 PUTL\n", cmd);
+		return;
+	}
+	if (!descriptor_bytes || descriptor_size == 0 || descriptor_size % 8 != 0)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_getl_cmd dropped: invalid descriptor (bytes=%p size=%u)\n",
+			static_cast<const void*>(descriptor_bytes), descriptor_size);
+		return;
+	}
+	if (element_count == 0 || element_count != descriptor_size / 8u)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_getl_cmd dropped: element_count=%u mismatches descriptor_size=%u (expected %u)\n",
+			element_count, descriptor_size, descriptor_size / 8u);
+		return;
+	}
+	if (!element_chunks || !element_sizes || !element_eals)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_getl_cmd dropped: null element arrays\n");
+		return;
+	}
+
+	// Snapshot descriptor + per-element bytes BEFORE taking the
+	// lock or hashing. Caller has already snapshotted; we copy
+	// defensively to remain self-contained.
+	std::vector<std::uint8_t> desc_snapshot(descriptor_bytes, descriptor_bytes + descriptor_size);
+
+	auto sha256_hex_of = [](const std::vector<std::uint8_t>& v, std::string& out_hex) -> bool {
+		unsigned char hash[32];
+		if (mbedtls_sha256_ret(v.data(), v.size(), hash, /*is224=*/0) != 0)
+		{
+			return false;
+		}
+		static constexpr char hex_chars[] = "0123456789abcdef";
+		char hex[65];
+		for (std::size_t i = 0; i < 32; ++i)
+		{
+			hex[i * 2]     = hex_chars[(hash[i] >> 4) & 0xF];
+			hex[i * 2 + 1] = hex_chars[hash[i] & 0xF];
+		}
+		hex[64] = '\0';
+		out_hex.assign(hex, 64);
+		return true;
+	};
+
+	std::string desc_sha;
+	if (!sha256_hex_of(desc_snapshot, desc_sha))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_getl_cmd dropped: descriptor sha256 failed for target_spu=%u tag=%u\n",
+			target_spu, tag);
+		return;
+	}
+
+	// Per-element snapshots + hashes.
+	std::vector<std::vector<std::uint8_t>> elem_snapshots(element_count);
+	std::vector<std::string> elem_shas(element_count);
+	for (std::uint32_t i = 0; i < element_count; ++i)
+	{
+		if (!element_chunks[i] || element_sizes[i] == 0)
+		{
+			std::fprintf(stderr,
+				"[spu_trace] record_spu_mfc_getl_cmd dropped: element %u has null/zero chunk (size=%u)\n",
+				i, element_sizes[i]);
+			return;
+		}
+		elem_snapshots[i].assign(element_chunks[i], element_chunks[i] + element_sizes[i]);
+		if (!sha256_hex_of(elem_snapshots[i], elem_shas[i]))
+		{
+			std::fprintf(stderr,
+				"[spu_trace] record_spu_mfc_getl_cmd dropped: element %u sha256 failed\n", i);
+			return;
+		}
+	}
+
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+
+	// Descriptor side-file MUST land before anything else.
+	if (!write_dma_listdesc_side_file(desc_sha, desc_snapshot.data(), descriptor_size))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] record_spu_mfc_getl_cmd dropped for target_spu=%u tag=%u: "
+			"descriptor side-file write failed; JSONL NOT emitted\n",
+			target_spu, tag);
+		return;
+	}
+
+	// Each element chunk MUST land. REUSE the existing
+	// `.dmachunk` pool — same content-addressed scheme as
+	// simple GET/PUT, so dedup is automatic.
+	for (std::uint32_t i = 0; i < element_count; ++i)
+	{
+		if (!write_dma_chunk_side_file(elem_shas[i], elem_snapshots[i].data(), element_sizes[i]))
+		{
+			std::fprintf(stderr,
+				"[spu_trace] record_spu_mfc_getl_cmd dropped for target_spu=%u tag=%u: "
+				"element %u chunk side-file write failed; JSONL NOT emitted\n",
+				target_spu, tag, i);
+			return;
+		}
+	}
+
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "spu_mfc_cmd");
+	os << ",\"target_spu\":";        append_u32(os, target_spu);
+	os << ",\"pc\":";                append_u32(os, pc);
+	os << ",\"cmd\":";               append_u32(os, cmd);
+	os << ",\"tag\":";               append_u32(os, tag);
+	os << ",\"size\":";              append_u32(os, descriptor_size);
+	os << ",\"lsa\":";               append_u32(os, lsa_dest_base);
+	os << ",\"eah\":";               append_u32(os, eah);
+	os << ",\"eal\":";               append_u32(os, descriptor_lsa);
+	// `ea_chunk_sha256` slot overload: descriptor SHA, so that
+	// the existing GET/PUT-aware parser shape stays compatible
+	// (every spu_mfc_cmd event carries some ea_chunk_sha256
+	// string). R8.4c parser-level treats this as the descriptor
+	// pointer when cmd=0x44.
+	os << ",\"ea_chunk_sha256\":\"" << desc_sha << '"';
+	// R8.4b additive list-DMA fields.
+	os << ",\"descriptor_sha256\":\"" << desc_sha << '"';
+	os << ",\"descriptor_size\":";   append_u32(os, descriptor_size);
+	os << ",\"element_chunks\":[";
+	for (std::uint32_t i = 0; i < element_count; ++i)
+	{
+		if (i) os << ",";
+		os << '"' << elem_shas[i] << '"';
+	}
+	os << "]";
+	os << ",\"element_sizes\":[";
+	for (std::uint32_t i = 0; i < element_count; ++i)
+	{
+		if (i) os << ",";
+		append_u32(os, element_sizes[i]);
+	}
+	os << "]";
+	os << ",\"element_eals\":[";
+	for (std::uint32_t i = 0; i < element_count; ++i)
+	{
+		if (i) os << ",";
+		append_u32(os, element_eals[i]);
+	}
+	os << "]";
+	os << "}";
+	emit_line(os.str());
+}
+
+void TraceWriter::record_mfc_dma_complete(std::uint32_t target_spu, std::uint32_t tag,
+	std::uint32_t transferred_bytes)
+{
+	if (!enabled()) return;
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "mfc_dma_complete");
+	os << ",\"target_spu\":";        append_u32(os, target_spu);
+	os << ",\"tag\":";               append_u32(os, tag);
+	os << ",\"transferred_bytes\":"; append_u32(os, transferred_bytes);
+	os << "}";
+	emit_line(os.str());
+}
+
+// R6.7 A.1 — write the captured EA bytes to
+// `<m_trace_path>.dma/<sha>.dmachunk`. Mirrors `write_image_side_file`
+// for `.spuimg` — same dedup-on-existing-SHA logic, same post-write
+// size verification, same caller-holds-mutex contract. Returns true
+// iff the side-file is on disk with exactly `size` bytes after the
+// call.
+bool TraceWriter::write_dma_chunk_side_file(const std::string& sha256_hex,
+	const std::uint8_t* bytes, std::uint32_t size)
+{
+	if (m_trace_path.empty())
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_chunk_side_file: m_trace_path is empty (writer state inconsistent)\n");
+		return false;
+	}
+
+	namespace fs = std::filesystem;
+	std::error_code ec;
+
+	// Per-trace `.dma/` directory. Created on demand. The canonical
+	// CC0 location (`behavior-freeze/fixtures/spu/dma/`) is populated
+	// by a separate post-capture workflow step that copies/dedups
+	// `.dmachunk` files from the per-trace directory; this writer
+	// only emits to the per-trace path to keep capture self-contained.
+	const fs::path dma_dir = fs::path(m_trace_path).concat(".dma");
+	fs::create_directories(dma_dir, ec);
+	if (ec)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_chunk_side_file: create_directories('%s') failed: %s\n",
+			dma_dir.string().c_str(), ec.message().c_str());
+		return false;
+	}
+	if (!fs::is_directory(dma_dir, ec))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_chunk_side_file: '%s' is not a directory after create_directories (ec=%s)\n",
+			dma_dir.string().c_str(), ec.message().c_str());
+		return false;
+	}
+
+	const fs::path file_path = dma_dir / (sha256_hex + ".dmachunk");
+
+	if (fs::exists(file_path, ec))
+	{
+		ec.clear();
+		const auto existing_size = fs::file_size(file_path, ec);
+		if (!ec && existing_size == size)
+		{
+			return true; // content-addressed dedup — same SHA + same size = same bytes.
+		}
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_chunk_side_file: '%s' exists with size %llu, expected %u — overwriting\n",
+			file_path.string().c_str(),
+			static_cast<unsigned long long>(existing_size), size);
+	}
+
+	{
+		std::ofstream of(file_path, std::ios::binary | std::ios::trunc);
+		if (!of.is_open())
+		{
+			std::fprintf(stderr,
+				"[spu_trace] write_dma_chunk_side_file: ofstream open('%s', binary|trunc) failed\n",
+				file_path.string().c_str());
+			return false;
+		}
+		of.write(reinterpret_cast<const char*>(bytes), static_cast<std::streamsize>(size));
+		if (!of.good())
+		{
+			const auto wrote = static_cast<long long>(of.tellp());
+			std::fprintf(stderr,
+				"[spu_trace] write_dma_chunk_side_file: short/failed write to '%s' (wrote ~%lld of %u)\n",
+				file_path.string().c_str(), wrote, size);
+			return false;
+		}
+		of.flush();
+	}
+
+	ec.clear();
+	const auto final_size = fs::file_size(file_path, ec);
+	if (ec)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_chunk_side_file: post-write file_size('%s') failed: %s\n",
+			file_path.string().c_str(), ec.message().c_str());
+		return false;
+	}
+	if (final_size != size)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_chunk_side_file: post-write size mismatch for '%s': on disk %llu, expected %u\n",
+			file_path.string().c_str(),
+			static_cast<unsigned long long>(final_size), size);
+		return false;
+	}
+
+	return true;
+}
+
+// R8.4b — descriptor side-file for GETL. Same dedup-on-existing-SHA
+// shape as `write_dma_chunk_side_file`, separate file extension
+// (`.dmalistdesc`) so the canonical pool can distinguish per-element
+// data chunks from list descriptors at a glance. Mirrors the
+// `.dmachunk` / `.spuimg` write contract: returns true iff the file
+// exists on disk with exactly `size` bytes after the call.
+bool TraceWriter::write_dma_listdesc_side_file(const std::string& sha256_hex,
+	const std::uint8_t* bytes, std::uint32_t size)
+{
+	if (m_trace_path.empty())
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_listdesc_side_file: m_trace_path is empty\n");
+		return false;
+	}
+
+	namespace fs = std::filesystem;
+	std::error_code ec;
+
+	const fs::path dma_dir = fs::path(m_trace_path).concat(".dma");
+	fs::create_directories(dma_dir, ec);
+	if (ec)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_listdesc_side_file: create_directories('%s') failed: %s\n",
+			dma_dir.string().c_str(), ec.message().c_str());
+		return false;
+	}
+	if (!fs::is_directory(dma_dir, ec))
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_listdesc_side_file: '%s' is not a directory after create_directories (ec=%s)\n",
+			dma_dir.string().c_str(), ec.message().c_str());
+		return false;
+	}
+
+	const fs::path file_path = dma_dir / (sha256_hex + ".dmalistdesc");
+
+	if (fs::exists(file_path, ec))
+	{
+		ec.clear();
+		const auto existing_size = fs::file_size(file_path, ec);
+		if (!ec && existing_size == size)
+		{
+			return true; // content-addressed dedup
+		}
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_listdesc_side_file: '%s' exists with size %llu, expected %u - overwriting\n",
+			file_path.string().c_str(),
+			static_cast<unsigned long long>(existing_size), size);
+	}
+
+	{
+		std::ofstream of(file_path, std::ios::binary | std::ios::trunc);
+		if (!of.is_open())
+		{
+			std::fprintf(stderr,
+				"[spu_trace] write_dma_listdesc_side_file: ofstream open('%s', binary|trunc) failed\n",
+				file_path.string().c_str());
+			return false;
+		}
+		of.write(reinterpret_cast<const char*>(bytes), static_cast<std::streamsize>(size));
+		if (!of.good())
+		{
+			const auto wrote = static_cast<long long>(of.tellp());
+			std::fprintf(stderr,
+				"[spu_trace] write_dma_listdesc_side_file: short/failed write to '%s' (wrote ~%lld of %u)\n",
+				file_path.string().c_str(), wrote, size);
+			return false;
+		}
+		of.flush();
+	}
+
+	ec.clear();
+	const auto final_size = fs::file_size(file_path, ec);
+	if (ec)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_listdesc_side_file: post-write file_size('%s') failed: %s\n",
+			file_path.string().c_str(), ec.message().c_str());
+		return false;
+	}
+	if (final_size != size)
+	{
+		std::fprintf(stderr,
+			"[spu_trace] write_dma_listdesc_side_file: post-write size mismatch for '%s': on disk %llu, expected %u\n",
+			file_path.string().c_str(),
+			static_cast<unsigned long long>(final_size), size);
+		return false;
+	}
+
+	return true;
+}
+
+} // namespace rpcs3::spu_trace
diff --git a/rpcs3/Emu/Cell/SPUTraceJsonl.h b/rpcs3/Emu/Cell/SPUTraceJsonl.h
new file mode 100644
index 000000000..d701c4c45
--- /dev/null
+++ b/rpcs3/Emu/Cell/SPUTraceJsonl.h
@@ -0,0 +1,330 @@
+// R5.8 A.3 — SPU PPU↔SPU trace JSONL writer.
+//
+// Self-contained, gated, disabled-by-default trace emitter that produces
+// JSONL events per the schema in `docs/SPU_TRACE_CAPTURE.md`. The
+// resulting trace file feeds the Rust-side `replay_trace` engine
+// (`rpcs3-spu-differential::trace_fmt`) so a captured C++ run can be
+// validated byte-exact against the Rust SPU stack.
+//
+// Activation:
+//   1. Set environment variable `RPCS3_SPU_TRACE_JSONL=/path/to/out.jsonl`
+//      before launching RPCS3.
+//   2. The writer opens the file lazily on the first emit call.
+//   3. When the env var is unset (or empty), every emit is a noinline
+//      atomic-load-and-return-fast path with zero file I/O.
+//
+// Determinism: a single global monotonic `seq` counter (`std::atomic<u64>`)
+// is incremented and bound to the event before serialization. Thread
+// safety: a single mutex serializes the file write so events appear in
+// `seq` order on disk. As of R5.9c, every SPU-side recorder takes a
+// `target_spu` argument (the source SPU's `lv2_id`) and emits it as a
+// `target_spu` field in the JSON line. The Rust-side R5.9a parser
+// validates per-SPU `final_state` terminality using this discriminator;
+// the R5.9b transformer groups events into per-SPU traces. PPU-side
+// recorders already carried `target_spu` (the destination SPU's
+// `lv2_id`); their semantics are unchanged in R5.9c.
+//
+// The writer has zero dependencies on RPCS3-specific types in its public
+// surface — every input is a plain C++ scalar (u32, optional u32, etc.).
+// Integration call sites convert RPCS3 internal state into these scalars
+// before invoking the recorder. See `docs/SPU_TRACE_CAPTURE_PATCH.md`
+// for the integration diffs.
+
+#pragma once
+
+#include <cstdint>
+#include <fstream>
+#include <mutex>
+#include <atomic>
+#include <optional>
+#include <string>
+#include <string_view>
+#include <unordered_set>
+#include <vector>
+
+namespace rpcs3::spu_trace {
+
+// Schema event-kind enum, mirrors the `kind` field in JSONL.
+enum class EventKind {
+	SpuRdch,
+	SpuWrch,
+	SpuRchcnt,
+	SpuPark,
+	SpuWake,
+	SpuStop,
+	FinalState,
+	SpuImage, // R5.9e.1 — SPU local store image metadata (bytes in side-file)
+	SpuMfcCmd,        // R6.7 A.1 — MFC cmd packet at wrch ch21 dispatch (with EA-chunk reference)
+	MfcDmaComplete,   // R6.7 A.1 — MFC tag completion observed after C++ do_mfc()/do_dma_transfer
+	PpuPushInmbox,
+	PpuPopOutmbox,
+	PpuSignal,
+};
+
+enum class ParkReason {
+	ChannelRead,
+	ChannelWrite,
+};
+
+// Channel snapshot used by `spu_park` (optional `channels_at_park`)
+// and the terminal `final_state`. Mirrors the Rust-side
+// `CapturedChannels` shape.
+struct ChannelsSnapshot
+{
+	std::optional<std::uint32_t> in_mbox;
+	std::optional<std::uint32_t> out_mbox;
+	std::optional<std::uint32_t> out_intr_mbox;
+	std::uint32_t snr1 = 0;
+	std::uint32_t snr2 = 0;
+};
+
+struct GprEntry
+{
+	std::uint32_t reg;
+	std::uint32_t value;
+};
+
+// Singleton trace writer. `instance()` returns a never-null reference;
+// the underlying writer is enabled iff the env var is set at the time
+// of first call. Subsequent env var changes are NOT picked up — capture
+// is bound at process startup for determinism.
+class TraceWriter
+{
+public:
+	// Returns the singleton. First call reads the env var and opens
+	// the JSONL file if set. Subsequent calls are O(1).
+	static TraceWriter& instance();
+
+	// Whether the writer is enabled (env var set, file opened OK).
+	// Hot-path emit functions short-circuit on this.
+	[[nodiscard]] bool enabled() const noexcept { return m_enabled.load(std::memory_order_relaxed); }
+
+	// === SPU-side recorders ====================================
+	//
+	// R5.9c: every SPU-side recorder takes a `target_spu` argument
+	// (the source SPU's `lv2_id`) as the first parameter. The recorder
+	// emits it as `"target_spu":<u32>` in the JSON line. For legacy
+	// single-SPU traces captured with R5.7/R5.8 writers (where this
+	// field was absent), the Rust R5.9a parser treats absence as
+	// `target_spu = 0` via `#[serde(default)]` — see
+	// `docs/SPU_TRACE_R5_9_MULTISPU_PLAN.md` § A.4.
+
+	// `spu_rdch`: dispatched at channel-read entry. `value` is empty
+	// if the read would stall (no value actually transferred); else
+	// holds the consumed value.
+	void record_spu_rdch(std::uint32_t target_spu, std::uint32_t pc, std::uint32_t channel,
+		std::optional<std::uint32_t> value, bool would_stall);
+
+	// `spu_wrch`: dispatched at channel-write entry. `value` is the
+	// value the SPU attempted to write regardless of stall outcome.
+	void record_spu_wrch(std::uint32_t target_spu, std::uint32_t pc, std::uint32_t channel,
+		std::uint32_t value, bool would_stall);
+
+	// `spu_rchcnt`: dispatched at rchcnt entry. Never stalls.
+	void record_spu_rchcnt(std::uint32_t target_spu, std::uint32_t pc, std::uint32_t channel, std::uint32_t count);
+
+	// `spu_park`: dispatched on channel-op stall after the
+	// would_stall=true rdch/wrch was already emitted. `channels` is
+	// optional — when populated, the Rust transformer emits an
+	// ExpectChannelState immediately after the ExpectSpuPark.
+	void record_spu_park(std::uint32_t target_spu, std::uint32_t pc, ParkReason reason, std::uint32_t channel,
+		const std::optional<ChannelsSnapshot>& channels);
+
+	// `spu_wake`: dispatched immediately after a parked SPU is
+	// resumed. `pc` MUST equal the preceding `spu_park`'s pc — the
+	// SPU re-executes the channel op at this address.
+	void record_spu_wake(std::uint32_t target_spu, std::uint32_t pc);
+
+	// `spu_stop`: dispatched at `stop` / `stopd` instruction handling.
+	void record_spu_stop(std::uint32_t target_spu, std::uint32_t pc, std::uint32_t stop_code);
+
+	// `final_state`: dispatched exactly once at SPU thread exit
+	// after `spu_stop`. `gprs` is the subset the capture chose to
+	// assert (NOT every non-zero GPR); typical policy is the
+	// homebrew's contract registers only.
+	void record_final_state(std::uint32_t target_spu, const std::vector<GprEntry>& gprs,
+		const ChannelsSnapshot& channels);
+
+	// R5.9e.3 — dispatched ONCE per SPU thread at thread entry, before
+	// any executed event for that target_spu. Snapshots `size` bytes
+	// from `ls_bytes` (the SPU's local store), computes the SHA-256
+	// of the snapshot, writes a content-addressed side-file at
+	// `<trace_path>.images/<sha256>.spuimg` (created on demand; not
+	// re-written if the same SHA already exists), and emits a JSONL
+	// `spu_image` event carrying the metadata. Subsequent calls with
+	// the same `target_spu` are no-ops (per-target_spu dedup via
+	// `m_emitted_images`); the SPU's image is captured exactly once
+	// per trace session even if `cpu_task` is re-entered after a
+	// pause/resume cycle.
+	//
+	// Per the R5.9e.1 schema: bytes are NEVER inlined in the JSONL
+	// (no base64, no hex). The side-file holds raw binary bytes; the
+	// JSONL holds only the metadata pointer.
+	//
+	// Caller-side requirements: `ls_bytes` must point to at least
+	// `size` valid bytes; `size` must equal the captured image size
+	// (typically `SPU_LS_SIZE` = 256 KB); `load_addr` is the LS offset
+	// where the image starts (usually 0); `entry_pc` is the SPU's
+	// initial PC. The function is safe to call from inside
+	// `spu_thread::cpu_task` as long as the SPU has not yet started
+	// executing — the caller is responsible for the snapshot timing.
+	void record_spu_image(std::uint32_t target_spu, const std::uint8_t* ls_bytes,
+		std::uint32_t size, std::uint32_t load_addr, std::uint32_t entry_pc);
+
+	// R6.7 A.1 — `spu_mfc_cmd`: emitted IMMEDIATELY AFTER the matching
+	// `spu_wrch ch21 (MFC_Cmd)` event, BEFORE the C++ `process_mfc_cmd()`
+	// dispatches the transfer. Caller (the runtime hook) is responsible
+	// for snapshotting `ea_bytes`/`ea_bytes_size` from EA via vm::_ptr
+	// BEFORE invoking this — the writer does not touch RPCS3 vm:: or LS.
+	// The recorder SHA-256-hashes the bytes, writes a content-addressed
+	// `<trace_path>.dma/<sha>.dmachunk` side-file (skipping if a file
+	// with the same SHA already exists with matching size), and emits
+	// the JSONL line referencing the SHA.
+	//
+	// Scope (R6.7 A.1): GET only (cmd code 0x40). The runtime hook is
+	// responsible for filtering: it MUST NOT call this for non-GET
+	// codes (PUT/list/atomic) — those surface as bare `spu_wrch ch21`
+	// and the parser rejects them with `UnsupportedMfcCmd`.
+	//
+	// Side-file write contract: same as `record_spu_image` — the JSONL
+	// line is emitted ONLY if the side-file landed on disk with the
+	// expected size. On any failure the call is dropped and the caller
+	// MUST NOT proceed with `record_mfc_dma_complete` for the same tag
+	// (the trace would reference a missing chunk).
+	void record_spu_mfc_cmd(std::uint32_t target_spu, std::uint32_t pc,
+		std::uint32_t cmd, std::uint32_t tag, std::uint32_t size,
+		std::uint32_t lsa, std::uint32_t eah, std::uint32_t eal,
+		const std::uint8_t* ea_bytes, std::uint32_t ea_bytes_size);
+
+	// R8.4b -- `spu_mfc_cmd` recorder for GETL (cmd 0x44,
+	// list-DMA EA -> LS). Caller (runtime hook) snapshots:
+	//
+	// - `descriptor_bytes`: `descriptor_size` bytes from the
+	//   SPU's LS at `descriptor_lsa & 0x3fff8`. Each 8-byte
+	//   slot is one list_element { u8 sb; u8 pad; be_t<u16> ts;
+	//   be_t<u32> ea; }.
+	//
+	// - `element_chunks[i]`: `element_sizes[i]` bytes from
+	//   `vm::_ptr<u8>(element_eals[i])` for each element.
+	//
+	// The recorder writes:
+	// 1. `<trace_path>.dma/<sha>.dmalistdesc` for descriptor bytes.
+	// 2. `<trace_path>.dma/<sha>.dmachunk` for each element
+	//    (REUSE of the existing pool -- dedup-friendly).
+	// 3. Single JSONL `spu_mfc_cmd` line with cmd=68, the
+	//    standard fields (size = descriptor_size, eal =
+	//    descriptor_lsa, lsa = lsa_dest_base, eah = 0), and
+	//    new fields: `descriptor_sha256`, `descriptor_size`,
+	//    `element_chunks` (array of N SHA hex strings),
+	//    `element_sizes` (array of N), `element_eals` (array
+	//    of N). The existing `ea_chunk_sha256` field is set to
+	//    the descriptor SHA so simple-GET/PUT-aware parsers
+	//    continue to see a valid SHA string in the slot.
+	//
+	// JSONL emit is dropped if any side-file write fails (same
+	// contract as simple GET/PUT). Caller MUST skip the
+	// subsequent `record_mfc_dma_complete` if so.
+	//
+	// Scope (R8.4b): GETL (0x44). R8.4e extends to PUTL (0x24)
+	// (symmetric LS → EA; wire format identical, only direction
+	// differs — caller provides LS-source snapshots instead of
+	// EA-source). GETLB (0x45) / GETLF (0x46) / PUTLB (0x25) /
+	// PUTLF (0x26) defer to R8.4f.
+	// Stall-and-notify (descriptor `sb` bit 0x80) defers to
+	// R8.5+; caller MUST refuse capture if any element has it.
+	void record_spu_mfc_getl_cmd(std::uint32_t target_spu, std::uint32_t pc,
+		std::uint32_t cmd, std::uint32_t tag,
+		std::uint32_t descriptor_size,
+		std::uint32_t lsa_dest_base,
+		std::uint32_t eah,
+		std::uint32_t descriptor_lsa,
+		const std::uint8_t* descriptor_bytes,
+		std::uint32_t element_count,
+		const std::uint8_t* const* element_chunks,
+		const std::uint32_t* element_sizes,
+		const std::uint32_t* element_eals);
+
+	// R6.7 A.1 — `mfc_dma_complete`: emitted after the C++
+	// `process_mfc_cmd()` returns. Per R6.7 design § 4.1 it MUST
+	// appear strictly after the matching `spu_mfc_cmd` and strictly
+	// before any `spu_rdch ch24 (RdTagStat)` that observes the tag
+	// completed. The replay parser uses the per-trace ordering to
+	// advance its tag-stat oracle.
+	void record_mfc_dma_complete(std::uint32_t target_spu, std::uint32_t tag,
+		std::uint32_t transferred_bytes);
+
+	// === PPU-side recorders ====================================
+
+	void record_ppu_push_inmbox(std::uint32_t target_spu, std::uint32_t value);
+
+	// `value` holds the value drained from out_mbox; empty when the
+	// PPU-side helper popped against an empty mailbox.
+	void record_ppu_pop_outmbox(std::uint32_t target_spu, std::optional<std::uint32_t> value);
+
+	// `slot` is 0 (SNR1) or 1 (SNR2). Out-of-range slots are dropped
+	// with a stderr diagnostic (defensive — should never happen).
+	void record_ppu_signal(std::uint32_t target_spu, std::uint32_t slot, std::uint32_t value);
+
+private:
+	TraceWriter();
+	~TraceWriter();
+	TraceWriter(const TraceWriter&) = delete;
+	TraceWriter& operator=(const TraceWriter&) = delete;
+
+	// Allocate the next monotonic seq value. Lock-free.
+	std::uint64_t next_seq() noexcept;
+
+	// Serialize `kind` payload to one JSONL line and write it
+	// atomically (under m_write_mutex). No-op if not enabled.
+	void emit_line(std::string_view line);
+
+	// R5.9e.3-fix — write the captured image bytes to
+	// `<m_trace_path>.images/<sha256>.spuimg` if the file does not
+	// already exist. Caller MUST hold `m_write_mutex`. Returns true
+	// iff the side-file is on disk with exactly `size` bytes after
+	// the call (either freshly written or pre-existing with matching
+	// size — the SHA-named-file dedup contract). Returns false on
+	// any failure (mkdir, ofstream open, partial write, post-write
+	// size mismatch). All failures emit a [spu_trace] line on stderr
+	// describing the path + reason. Callers MUST check the return
+	// value and refuse to emit the JSONL `spu_image` event when this
+	// returns false — the v4-bug fix that surfaced when the JSONL
+	// referenced a `.spuimg` that never made it to disk.
+	bool write_image_side_file(const std::string& sha256_hex,
+		const std::uint8_t* bytes, std::uint32_t size);
+
+	// R6.7 A.1 — write the captured EA bytes to
+	// `<m_trace_path>.dma/<sha256>.dmachunk` if a file with the same
+	// SHA-named name does NOT already exist with matching size.
+	// Caller MUST hold `m_write_mutex`. Same return-and-failure
+	// semantics as `write_image_side_file`. The caller (`record_spu_mfc_cmd`)
+	// refuses to emit the JSONL `spu_mfc_cmd` event when this returns
+	// false so the trace never references a missing/short `.dmachunk`.
+	bool write_dma_chunk_side_file(const std::string& sha256_hex,
+		const std::uint8_t* bytes, std::uint32_t size);
+
+	// R8.4b -- write captured descriptor list bytes (N * 8 bytes
+	// total) to `<trace_path>.dma/<sha>.dmalistdesc`. Same dedup
+	// contract as `write_dma_chunk_side_file`: returns true iff
+	// the file exists on disk with exactly `size` bytes after
+	// the call. Caller MUST hold `m_write_mutex`.
+	bool write_dma_listdesc_side_file(const std::string& sha256_hex,
+		const std::uint8_t* bytes, std::uint32_t size);
+
+	std::atomic<bool> m_enabled{false};
+	std::atomic<std::uint64_t> m_seq{0};
+	std::ofstream m_file;
+	std::mutex m_write_mutex;
+	// R5.9e.3 — trace file path captured at writer construction time.
+	// Used to derive the side-file directory `<m_trace_path>.images/`
+	// for `record_spu_image`. Empty when the writer is disabled.
+	std::string m_trace_path;
+	// R5.9e.3 — set of `target_spu` ids for which `spu_image` has
+	// already been emitted on this writer. Guarded by `m_write_mutex`.
+	// Ensures every SPU's image lands at most once in the JSONL even
+	// if `record_spu_image` is invoked multiple times for the same
+	// SPU (e.g., from a re-entered `spu_thread::cpu_task`).
+	std::unordered_set<std::uint32_t> m_emitted_images;
+};
+
+} // namespace rpcs3::spu_trace
