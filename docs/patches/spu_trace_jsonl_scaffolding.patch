+void TraceWriter::record_spu_rdch(std::uint32_t target_spu, std::uint32_t pc, std::uint32_t channel,
+	std::optional<std::uint32_t> value, bool would_stall)
+{
+	if (!enabled()) return;
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, true, "spu_rdch");
+	os << ",\"target_spu\":"; append_u32(os, target_spu);
+	os << ",\"pc\":";       append_u32(os, pc);
+	os << ",\"channel\":";  append_u32(os, channel);
+	os << ",\"value\":";    append_optional_u32(os, value);
+	os << ",\"would_stall\":"; append_bool(os, would_stall);
+	os << "}";
+	emit_line(os.str());
+}
+
