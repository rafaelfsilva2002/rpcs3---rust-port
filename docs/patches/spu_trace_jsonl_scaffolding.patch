+void TraceWriter::record_ppu_push_inmbox(std::uint32_t target_spu, std::uint32_t value)
+{
+	if (!enabled()) return;
+	std::lock_guard<std::mutex> lk(m_write_mutex);
+	const auto seq = next_seq();
+	std::ostringstream os;
+	start_event(os, seq, false, "ppu_push_inmbox");
+	os << ",\"target_spu\":"; append_u32(os, target_spu);
+	os << ",\"value\":";      append_u32(os, value);
+	os << "}";
+	emit_line(os.str());
+}
